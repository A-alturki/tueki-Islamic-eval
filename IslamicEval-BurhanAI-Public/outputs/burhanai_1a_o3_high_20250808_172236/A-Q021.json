    {
      "id": "ci_689631b3a15c8195b6b72c7c867fcaa90dade1b74082168a",
      "code": "spans_strings=[\n\"الرِّجَالُ قَوَّامُونَ عَلَى النِّسَاءِ بِمَا فَضَّلَ اللَّهُ بَعْضَهُمْ عَلَى بَعْضٍ وَبِمَا أَنْفَقُوا مِنْ أَمْوَالِهِمْ\",\n\"وَأَلْفَيَا سَيِّدَهَا لَدَى الْبَابِ\",\n\"كل نفس من بني آدم سيد، فالرجل سيد أهله، والمرأة سيدة بيتها\",\n\"استوصوا بالنساء خيرا فإنما هن عوان عندكم\",\n\"كلكم راع وكلكم مسؤول عن رعيته، الإمام راع ومسؤول عن رعيته، والرجل راع في أهله وهو مسؤول عن رعيته\",\n\"والرجل في أهله راع هو مسئول عن رعيته\",\n]\nindices=[]\nfor phrase in spans_strings:\n    start=text.find(phrase)\n    indices.append((phrase,start))\nindices",
      "container_id": "cntr_6896310305508190b5475d7da78e215209e2e63408360228",
      "outputs": null,
      "status": "completed",
      "type": "code_interpreter_call"
    },
