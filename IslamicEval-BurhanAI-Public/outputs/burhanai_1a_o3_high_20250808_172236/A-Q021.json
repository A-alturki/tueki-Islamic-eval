      "id": "ci_689631c73efc8195b28b58d36b5959de0dade1b74082168a",
      "code": "spans=[]\nfor phrase,start in indices:\n    end=start+len(phrase)\n    assert text[start:end]==phrase\n    spans.append(dict(span_start=start, span_end=end, span_text=phrase))\nspans",
      "container_id": "cntr_6896310305508190b5475d7da78e215209e2e63408360228",
      "outputs": null,
      "status": "completed",
