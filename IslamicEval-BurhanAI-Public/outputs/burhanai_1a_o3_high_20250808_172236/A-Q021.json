    {
      "id": "ci_689631bfa1f4819598cc7bebfb150a900dade1b74082168a",
      "code": "dups={}\nfor phrase in spans_strings:\n    idxs=[]\n    start=0\n    while True:\n        pos=text.find(phrase,start)\n        if pos==-1:\n            break\n        idxs.append(pos)\n        start=pos+1\n    dups[phrase]=idxs\ndups",
      "container_id": "cntr_6896310305508190b5475d7da78e215209e2e63408360228",
      "outputs": null,
      "status": "completed",
      "type": "code_interpreter_call"
