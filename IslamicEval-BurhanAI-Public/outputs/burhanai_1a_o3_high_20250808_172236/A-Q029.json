      "code": "spans = []\nspans.append((\"وَلَمَّا بَلَغَ أَشُدَّهُ وَاسْتَوَىٰ أَتْلُجَ الْبَيْتَ حِينَ بَلَغَ أَنِ اعْبُدُوا اللَّهَ رَبِّي وَرَبَّكُمْ ۖ إِنَّنِي خَشِيتُ أَن تَقْتُلُونِ\", \"Aya\"))\nspans.append((\"أَنْتَ آدَمُ الَّذِي أَغْوَيْتَ النَّاسَ وَأَخْرَجْتَهُمْ مِنَ الْجَنَّةِ\", \"Hadith\"))\nspans.append((\"وَلَا تَزِرُ وَازِرَةٌ وِزْرَ أُخْرَىٰ\", \"Aya\"))\nspans.append((\"أنت آدم الذي أغويت الناس وأخرجتهم من الجنة\", \"Hadith\"))\nspans.append((\"أنت آدم أبو البشر، خلقك الله بيده، وأسجد لك ملائكته، ثم تخرج الناس من الجنة تأكل من الشجرة\", \"Hadith\"))\nspans.append((\"قال له موسى أنت آدم الذي أغويت الناس وأخرجتهم من الجنة؟ فقال له آدم: أنت موسى الذي أعطاه الله علم كل شيء؟\", \"Hadith\"))\nspans.append((\"أنت موسى الذي أعطاه علم كل شيء\", \"Hadith\"))\nspans.append((\"أن الخضر قال له: ما علمي وما علمك إلى كما نقص هذا العصفور من البحر\", \"Hadith\"))\nspans.append((\"فَقَالَ رَبِّ إِنَّ ابْنِي مِنْ أَهْلِي وَإِنَّ وَعْدَكَ الْحَقُّ وَأَنْتَ أَحْكَمُ الْحَاكِمِينَ\", \"Aya\"))\n",
