      "code": "def trim_span(start, end):\n    text = raw[start:end]\n    # remove undesired edge characters as per rule\n    # remove whitespace and punctuation defined\n    trim_chars = set(' \\n\\t\"\\'«»“”„‟‹›‚‘’()[]{}<>،؛:.,!?…ـ')\n    # We cannot remove internal. Only edges.\n    while text and text[0] in trim_chars:\n        start += 1\n        text = raw[start:end]\n    while text and text[-1] in trim_chars:\n        end -=1\n        text = raw[start:end]\n    return start,end,raw[start:end]\n\nspans = [(302,340), (669,689), (704,722), (738,758), (1336,1374), (3527,3568), (3581,3619), (3670,3705), (4221,4248)]\nfinal_spans=[]\nfor s,e in spans:\n    ns,ne,text=trim_span(s,e)\n    assert raw[ns:ne]==text\n    final_spans.append((ns,ne,text))\nfinal_spans",
