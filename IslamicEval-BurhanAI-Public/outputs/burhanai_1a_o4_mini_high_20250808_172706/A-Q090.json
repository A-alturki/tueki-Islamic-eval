    {
      "id": "ci_689632462ec08195bef1599ebef9ee360391df4626c8ea76",
      "code": "# Build final list\nresult_spans = []\n# quotes\nfor startq,endq,seg in segments:\n    span_start = startq+1\n    span_end = endq-1  # endq is index of closing quote, we want up to closing quote start, so seg ends at endq-1 inclusive. But slicing raw[span_start:endq] = seg. So span_end should be endq.\n    # Actually seg = raw[span_start:endq], so endq is exclusive-end. So span_end=endq.\n    span_end = endq\n    text = seg.strip()  # seg has no surrounding whitespace.\n    # classification\n    if text.startswith(\"أفضل الكسب\") or text.startswith(\"لأن يأخذ\") or text.startswith(\"ثلاث فيهنّ\"):\n        ctype=\"Hadeeth\"\n    else:\n        ctype=\"Aya\"\n    result_spans.append((span_start, span_end, text, ctype))\n# brackets\nfor startb,endb,seg in segments2:\n    span_start = startb+1\n    span_end = endb\n    text = seg.strip()\n    # classification as Aya\n    ctype=\"Aya\"\n    result_spans.append((span_start, span_end, text, ctype))\n\n# sort\nresult_spans_sorted = sorted(result_spans, key=lambda x: x[0])\nfor s in result_spans_sorted:\n    print(s[0],s[1], s[2][:30]+\"...\", s[3])",
