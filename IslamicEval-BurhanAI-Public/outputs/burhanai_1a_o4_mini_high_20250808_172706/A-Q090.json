      "id": "ci_6896321f6b8c8195962e6d49526a16790391df4626c8ea76",
      "code": "# extract all quoted segments\nsegments = []\ni = 0\nwhile True:\n    start = raw.find('\"', i)\n    if start == -1:\n        break\n    end = raw.find('\"', start+1)\n    if end == -1:\n        break\n    seg = raw[start+1:end]\n    segments.append((start, end+1, seg))  # end+1 include closing quote\n    i = end+1\n\nfor idx, seg in segments:\n    print(idx, repr(seg[:30]+\"...\"+seg[-30:]), \"len\", len(seg))",
