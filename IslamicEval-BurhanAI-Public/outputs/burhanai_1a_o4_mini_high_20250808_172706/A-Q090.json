      "id": "ci_6896322ba8348195b929e971ad9d38e90391df4626c8ea76",
      "code": "# extract segments between '﴿' and '﴾'\nsegments2 = []\ni = 0\nwhile True:\n    start = raw.find('﴿', i)\n    if start == -1:\n        break\n    end = raw.find('﴾', start+1)\n    if end == -1:\n        break\n    seg = raw[start+1:end]\n    segments2.append((start, end+1, seg))\n    i = end+1\n\nfor start, end, seg in segments2:\n    print(start, end, repr(seg[:30]+\"...\"+seg[-30:]), \"len\", len(seg))",
