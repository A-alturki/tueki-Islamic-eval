      "id": "ci_6896316607d081958f1bea963034f9c602391672a609ddc5",
      "code": "# Let's find spans\nraw_text = raw\nspans = []\n\n# define a helper to find all occurrences of substring\ndef find_all(sub):\n    starts = []\n    start = 0\n    while True:\n        idx = raw_text.find(sub, start)\n        if idx == -1:\n            break\n        starts.append(idx)\n        start = idx+1\n    return starts\n\n# list of span texts and type\ncandidates = [\n    (\"شَهْرُ رَمَضَانَ الَّذِي أُنْزِلَ فِيهِ الْقُرْآنُ\", \"Aya\"),\n    (\"أنزلت صحف إبراهيم في أول ليلة من رمضان، وأنزلت التوراة لست مضين من رمضان، والإنجيل لثلاث عشرة خلت من رمضان، وأنزل الله القرآن لأربع وعشرين خلت من رمضان\", \"Hadith\"),\n    (\"شهر رمضان الذي أنزل فيه القرآن\", \"Aya\"),\n    (\"شهر رمضان الذي أنزل فيه القرآن هدى للناس وبينات من الهدى والفرقان فمن شهد منكم الشهر فليصمه ومن كان مريضا أو على سفر فعدة من أيام أخر يريد الله بكم اليسر ولا يريد بكم العسر ولتكملوا العدة ولتكبروا الله على ما هداكم ولعلكم تشكرون\", \"Aya\"),\n    (\"الذي أنزل فيه القرآن\", \"Aya\"),\n    (\"صلاة الأوابين إذا رمضت الفصال\", \"Hadith\"),\n    (\"إنا أنزلناه في ليلة القدر\", \"Aya\"),\n    (\"إنا أنزلناه في ليلة مباركة\", \"Aya\"),\n    (\"وقرآنا فرقناه\", \"Aya\"),\n    (\"فلا أقسم بمواقع النجوم\", \"Aya\")\n]\n\n# Now find occurrences\nspan_instances = []\nfor text, typ in candidates:\n    occs = find_all(text)\n    for o in occs:\n        span_instances.append((o, text, typ))\n# sort by start\nspan_instances_sorted = sorted(span_instances)\n# print occurrences\nfor o,text,typ in span_instances_sorted:\n    print(o, o+len(text), typ, text[:30]+\"...\")",
