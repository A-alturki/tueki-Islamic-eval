          "annotations": [],
          "text": "{\"citations\":[{\"span_start\":64,\"span_end\":143,\"span_text\":\"ءَأَنتَ ‌قُلۡتَ ‌لِلنَّاسِ ٱتَّخِذُونِي وَأُمِّيَ إِلَٰهَيۡنِ مِن دُونِ ٱللَّهِ\",\"citation_type\":\"Aya\"},{\"span_start\":176,\"span_end\":405,\"span_text\":\"مَا قُلْتُ لَهُمْ إِلَّا مَا أَمَرْتَنِي بِهِ أَنِ اعْبُدُوا اللَّهَ رَبِّي وَرَبَّكُمْ وَكُنتُ عَلَيْهِمْ شَهِيدًا مَا دُمْتُ فِيهِمْ فَلَمَّا تَوَفَّيْتَنِي كُنتَ أَنْتَ الرَّقِيبَ عَلَيْهِمْ وَأَنْتَ عَلَى كُلِّ شَيْءٍ شَهِيدٌ\",\"citation_type\":\"Aya\"},{\"span_start\":634,\"span_end\":1242,\"span_text\":\"وَكَذَلِكَ نُرِي إِبْرَاهِيمَ مَلَكُوتَ السَّمَاوَاتِ وَالأَرْضِ وَلِيَكُونَ مِنَ الْمُوقِنِينَ * فَلَمَّا جَنَّ عَلَيْهِ اللَّيْلُ رَأَى كَوْكَبًا قَالَ هَذَا رَبِّي فَلَمَّا أَفَلَ قَالَ لَا أُحِبُّ الْآفِلِينَ * فَلَمَّا رَأَى الْقَمَرَ بَاغِرًا قَالَ هَذَا رَبِّي فَلَمَّا أَفَلَ قَالَ لَئِن لَّمْ يَهْدِنِي رَبِّي لَأَكُونَنَّ مِنَ الْقَوْمِ الضَّالِّينَ * فَلَمَّا رَأَى الشَّمْسَ بَاغِرًا قَالَ هَذَا رَبِّي هَذَا أَكْبَرُ فَلَمَّا أَفَلَتْ قَالَ يَا قَوْمِ إِنِّي بَرِيءٌ مِّمَّا تُشْرِكُونَ * إِنِّي وَجَّهْتُ وَجْهِي لِلَّذِي فَطَرَ السَّمَاوَاتِ وَالأَرْضَ حَنِيفًا وَمَا أَنَا مِنَ الْمُشْرِكِينَ\",\"citation_type\":\"Aya\"},{\"span_start\":1788,\"span_end\":1850,\"span_text\":\"أأنتَ يا عيسى قلتَ للناس اجعلوني أنا وأمذ] إلَهين، من دون الله\",\"citation_type\":\"Aya\"},{\"span_start\":2072,\"span_end\":2139,\"span_text\":\"يا عيسى بن مريم، هل قلت للناس: صَيِّروني وأمي معبودَيْن من دون الله\",\"citation_type\":\"Aya\"},{\"span_start\":2230,\"span_end\":2309,\"span_text\":\"ءَأَنتَ ‌قُلۡتَ ‌لِلنَّاسِ ٱتَّخِذُونِي وَأُمِّيَ إِلَٰهَيۡنِ مِن دُونِ ٱللَّهِ\",\"citation_type\":\"Aya\"},{\"span_start\":2347,\"span_end\":2472,\"span_text\":\"وَإِذۡ قَالَ ٱللَّهُ يَٰعِيسَى ٱبۡنَ مَرۡيَمَ ءَأَنتَ ‌قُلۡتَ ‌لِلنَّاسِ ٱتَّخِذُونِي وَأُمِّيَ إِلَٰهَيۡنِ مِن دُونِ ٱللَّهِ\",\"citation_type\":\"Aya\"},{\"span_start\":4206,\"span_end\":4270,\"span_text\":\"يا عيسى ابن مريم أأنت قلت للناس اجعلوني وأمي معبودين من دون الله\",\"cit