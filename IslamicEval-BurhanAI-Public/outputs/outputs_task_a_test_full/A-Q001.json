      "code": "def extract_span(text, open_idx, close_idx_inclusive):\r\n    start = open_idx + 1\r\n    end = close_idx_inclusive - 1 if close_idx_inclusive is not None else len(text) - 1\r\n    # Trim whitespace at edges\r\n    while start <= end and text[start].isspace():\r\n        start += 1\r\n    while end >= start and text[end].isspace():\r\n        end -= 1\r\n    span = text[start:end+1]\r\n    return start, end+1, span  # end is exclusive\r\ns1 = extract_span(text, 401, 595)\r\ns1",
