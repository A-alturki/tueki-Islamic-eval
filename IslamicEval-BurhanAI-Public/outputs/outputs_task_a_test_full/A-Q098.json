      "code": "def trim_edges(s):\r\n    # characters to trim: whitespace and quotes and punctuation per spec\r\n    trim_chars = set([' ', '\\t', '\\n', '\\r',\r\n                      \"'\", '\"', '«', '»', '(', ')', '[', ']', '،', '؛', ':', '.', ',', '!', '?', '…'])\r\n    # Additionally possible English punctuation\r\n    # We'll strip from both ends iteratively\r\n    start = 0\r\n    end = len(s)\r\n    while start < end and s[start] in trim_chars:\r\n        start += 1\r\n    while end > start and s[end-1] in trim_chars:\r\n        end -= 1\r\n    return s[start:end], start, end\r\n\r\n# For first quote\r\nstart_q = start_quote+1\r\nend_q = end_quote\r\nraw1 = text[start_q:end_q]\r\ntrimmed1, offset_s1, offset_e1 = trim_edges(raw1)\r\nspan_start1 = start_q + offset_s1\r\nspan_end1 = start_q + offset_e1\r\nprint(raw1[:20], '...', raw1[-20:])\r\nprint(trimmed1[:20], '...', trimmed1[-20:])\r\nprint(span_start1, span_end1, trimmed1[-1], text[span_end1:span_end1+5])",
