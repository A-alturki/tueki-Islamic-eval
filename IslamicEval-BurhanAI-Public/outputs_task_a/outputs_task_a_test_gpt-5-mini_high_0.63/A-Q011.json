      "id": "ci_689623cf19308190bebdc9cb6a5685d200572a89964e2a2d",
      "code": "def classify_span(start, end):\n    # examine ±64 chars around start\n    left = max(0, start-64)\n    right = min(len(text), end+64)\n    context = text[left:right]\n    return context\n\nfor start,end,span in spans:\n    ctx = classify_span(start,end)\n    print(\"Span:\", span)\n    print(\"Context:\", repr(ctx))\n    print(\"----\")",
      "container_id": "cntr_689623aac9b08190a7cbd56005be770805348c3f24d3d593",
