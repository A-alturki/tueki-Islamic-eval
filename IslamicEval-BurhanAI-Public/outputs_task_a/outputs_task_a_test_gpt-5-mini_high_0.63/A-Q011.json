      "code": "spans = []\nfor m in matches:\n    start = m.start(1)\n    end = m.end(1)\n    span_text = text[start:end]\n    spans.append((start, end, span_text))\nspans",
      "container_id": "cntr_689623aac9b08190a7cbd56005be770805348c3f24d3d593",
