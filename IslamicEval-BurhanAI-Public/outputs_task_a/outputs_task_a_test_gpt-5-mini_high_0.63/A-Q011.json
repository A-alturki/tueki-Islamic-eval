      "id": "ci_689623c34e008190983119e8d38676ba00572a89964e2a2d",
      "code": "import re\nmatches = list(re.finditer(r'\"(.*?)\"', text, flags=re.S))\nfor m in matches:\n    start = m.start(1)\n    end = m.end(1)\n    print(\"Match text:\", m.group(1))\n    print(\"start, end:\", start, end)\n    print(\"raw[start:end]:\", repr(text[start:end]))\n    print(\"---\")",
