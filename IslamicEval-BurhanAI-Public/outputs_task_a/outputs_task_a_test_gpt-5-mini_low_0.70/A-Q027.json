      "code": "spans=[]\nimport re\nfor m in re.finditer(r'\\(aya_start\\)(.*?)\\(aya_end\\)',s,flags=re.S):\n    txt=m.group(1)\n    # trim per rules: remove surrounding punctuation and quotes etc\n    trimmed=txt.strip(\" \\n\\t\\r\\\"'«»()[]{}<>،؛:.,!?…ـ\")\n    start=s.find(trimmed,m.start())\n    spans.append((start,start+len(trimmed),trimmed,'Aya'))\n# find hadith quote \"إنما بعثت معلما\"\nfor m in re.finditer(r'\\\"?إنما بعثت معلما\\\"?',s):\n    txt=m.group(0).strip('\"')\n    # ensure length >=10 Arabic letters: it's short but clearly quoted hadith\n    start=s.find(txt,m.start())\n    spans.append((start,start+len(txt),txt,'Hadeeth'))\nspans\n",
