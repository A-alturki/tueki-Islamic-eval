      "code": "results = []\n# first ayah\nfor s, ctype in [(candidates[0],\"Aya\"), (candidates[1],\"Aya\")]:\n    cidx = text.find(s)\n    # compute byte start\n    start_byte = len(text[:cidx].encode('utf-8'))\n    end_byte = start_byte + len(s.encode('utf-8'))\n    # verify\n    sliced = raw[start_byte:end_byte].decode('utf-8')\n    print(\"verify slice == span?\", sliced == s)\n    results.append({\"span_start\": start_byte, \"span_end\": end_byte, \"span_text\": s, \"citation_type\": ctype})\n\n# hadith after marker\nquote_idx = text.find('\"أَ', midx)\nif quote_idx != -1:\n    span_cidx = quote_idx + 1  # position of أ\n    s = text[span_cidx:span_cidx+1]  # single char 'أ' plus maybe haraka; ensure includes diacritic\n    # but the hadith had 'أَ' two chars (Alef with hamza and fatha) in Unicode counts: let's capture until newline or closing quote\n    # find end: next quote or newline\n    end_pos_candidate = len(text)\n    next_quote2 = text.find('\"', span_cidx+1)\n    next_nl = text.find('\\n', span_cidx+1)\n    if next_quote2 != -1:\n        end_pos = next_quote2\n    elif next_nl != -1:\n        end_pos = next_nl\n    else:\n        end_pos = len(text)\n    s = text[span_cidx:end_pos]\n    # trim whitespace and punctuation according to rules (but internal has only 'أَ')\n    s = s.strip(\" \\t\\n\\r«»\\\"'()[]{}<>،؛:.,!?…ـ\")\n    cidx = span_cidx\n    start_byte = len(text[:cidx].encode('utf-8'))\n    end_byte = start_byte + len(s.encode('utf-8'))\n    print(\"hadith span text repr:\", repr(s), \"chars:\", len(s))\n    sliced = raw[start_byte:end_byte].decode('utf-8')\n    print(\"verify slice == span?\", sliced == s)\n    results.append({\"span_start\": start_byte, \"span_end\": end_byte, \"span_text\": s, \"citation_type\": \"Hadeeth\"})\nelse:\n    print(\"no quote found for hadith\")",
