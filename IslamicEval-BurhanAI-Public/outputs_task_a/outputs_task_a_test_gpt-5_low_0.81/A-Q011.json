    {
      "id": "ci_689623a61a208194bacea982efefbce1014fd41bc11d828a",
      "code": "spans = []\nfor m in re.finditer(r'“([^”]+)”|\"([^\"]+)\"', raw):\n    inner = m.group(1) if m.group(1) is not None else m.group(2)\n    # find the exact index of inner within m.group(0)\n    start = raw.find(inner, m.start(), m.end())\n    end = start + len(inner)\n    spans.append((start, end, inner))\nspans",
