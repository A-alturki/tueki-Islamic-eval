      "code": "import re, json, textwrap\r\n\r\nraw = raw_text\r\n\r\nspans = []\r\n\r\n# Define the exact quoted texts to search\r\ntargets = [\r\n    (\"وَمَن يَكُن حَلِيمًا وَمَن يَسْرِف فَإِنَّ اللَّهَ غَنِيٌ عَنْهُ\", \"Aya\"),\r\n    (\"لا بُخلَ فيما يُعتَدُّ بِهِ\", \"Hadith\"),\r\n    (\"وَلَوْ أَنَّ قُرَيْشًا يُفْتَنُونَ فِي الَّذِي يُوعَدُونَ مِن شَرِّ الدَّجَالِ وَرِقَامٍ وَنِفَاقٍ وَجَمعٍ\", \"Aya\"),\r\n    (\"لا تُبَخِلِ المَرءَ في حَياتِهِ فَإِنَّ اللَّهَ يُبَخِلُ مَن يُبَخِلُ وَيُعطي مَن يُعطي\", \"Hadith\"),\r\n]\r\n\r\nfor text, typ in targets:\r\n    start = 0\r\n    while True:\r\n        idx = raw.find(text, start)\r\n        if idx == -1:\r\n            break\r\n        spans.append((idx, idx+len(text), text, typ))\r\n        start = idx + 1\r\n\r\nspans, len(spans)",
