      "code": "def classify_span(start, end, text):\r\n    # check following 100 chars for \"رواه\"\r\n    context_after = content[end:end+100]\r\n    context_before = content[max(0, start-100):start]\r\n    # heuristics\r\n    if \"رواه\" in context_after or \"الرسول\" in context_before:\r\n        return \"Hadeeth\"\r\n    if \"البقرة\" in context_after or \"النمل\" in context_after or \"سورة\" in context_after or \"القرآن\" in context_before or \"الله تعالى\" in context_before:\r\n        return \"Aya\"\r\n    # fallback: use says \"الله تعالى\"\r\n    if \"الله تعالى\" in context_before:\r\n        return \"Aya\"\r\n    return \"Aya\"\r\n\r\nclassified = []\r\nfor start, end, inner in spans:\r\n    c = classify_span(start, end, inner)\r\n    classified.append((start, end, inner, c))\r\nclassified",
