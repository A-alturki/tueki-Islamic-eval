          "text": "{\"citations\":[{\"span_start\":124,\"span_end\":247,\"span_text\":\"أَيُحِبُّ أَحَدُكُمْ أَنْ يَأْكُلَ لَحْمَ أَخِيهِ مَيْتًا فَكَرِهْتُمُوهُ وَاتَّقُوا اللَّهَ إِنَّ اللَّهَ تَوَّابٌ رَحِيمٌ\",\"citation_type\":\"Aya\"},{\"span_start\":315,\"span_end\":332,\"span_text\":\"أتدرون ما الغيبة؟\",\"citation_type\":\"Hadeeth\"},{\"span_start\":365,\"span_end\":386,\"span_text\":\"هي ذكرك أخاك بما يكره\",\"citation_type\":\"Hadeeth\"},{\"span_start\":398,\"span_end\":428,\"span_text\":\"أفرأيت لو كان في أخيك ما تقول؟\",\"citation_type\":\"Hadeeth\"},{\"span_start\":436,\"span_end\":499,\"span_text\":\"إن كان فيه ما تقول فقد اغتبته، وإن لم يكن فيه ما تقول فقد بهتّه\",\"citation_type\":\"Hadeeth\"},{\"span_start\":2259,\"span_end\":2530,\"span_text\":\"يَا أَيُّهَا الَّذِينَ آَمَنُوا اجْتَنِبُوا كَثِيرًا مِنَ الظَّنِّ إِنَّ بَعْضَ الظَّنِّ إِثْمٌ وَلَا تَجَسَّسُوا وَلَا يَغْتَبْ بَعْضُكُمْ بَعْضًا أَيُحِبُّ أَحَدُكُمْ أَنْ يَأْكُلَ لَحْمَ أَخِيهِ مَيْتًا فَكَرِهْتُمُوهُ وَاتَّقُوا اللَّهَ إِنَّ اللَّهَ تَوَّابٌ رَحِيمٌ\",\"citation_type\":\"Aya\"},{\"span_start\":2988,\"span_end\":3020,\"span_text\":\"وَلا يَغْتَبْ بَعْضُكُمْ بَعْضاً\",\"citation_type\":\"Aya\"},{\"span_start\":3042,\"span_end\":3059,\"span_text\":\"أتدرون ما الغيبة؟\",\"citation_type\":\"Hadeeth\"},{\"span_start\":3092,\"span_end\":3113,\"span_text\":\"هي ذكرك أخاك بما يكره\",\"citation_type\":\"Hadeeth\"},{\"span_start\":3120,\"span_end\":3149,\"span_text\":\"أفرأيت لو كان في أخى ما أقول؟\",\"citation_type\":\"Hadeeth\"},{\"span_start\":3156,\"span_end\":3218,\"span_text\":\"إن كان فيه ما تقول فقد اغتبته وإن لم يكن فيه ما تقول فقد بهتّه\",\"citation_type\":\"Hadeeth\"},{\"span_start\":3361,\"span_end\":3418,\"span_text\":\"أَيُحِبُّ أَحَدُكُمْ أَنْ يَأْكُلَ لَحْمَ أَخِيهِ مَيْتاً\",\"citation_type\":\"Aya\"},{\"span_start\":4094,\"span_end\":4140,\"span_text\":\"وهل يكبّ النّاس على مناخرهم إلّا حصائد ألسنتهم\",\"citation_type\":\"Hadeeth\"},{\"span_start\":948,\"span_end\":1005,\"span_text\":\"أهل النار من ملأ الله أذنيه من ثناء الناس شرًّا، وهو يسمع\",\"citation_type\":\"Hadeeth\"},{\"span_start\":1016,\"span_end\":1076,\"span_text\":\"إن لله ملائكة تنطق على ألسنة بني آدم بما في المرء من خير وشر\",\"citation_type\":\"Hadeeth\"},{\"span_start\":1449,\"span_end\":1537,\"span_text\":\"إن الله إذا كره عبدًا، نادى جبريل: إني كرهت فلانًا، فأبغضوه، ثم توضع له البغضاء في الأرض\",\"citation_type\":\"Hadeeth\"},{\"span_start\":1799,\"span_end\":1826,\"span_text\":\"أَتَدْرُونَ مَا الْغِيبَةُ؟\",\"citation_type\":\"Hadeeth\"},{\"span_start\":1873,\"span_end\":1904,\"span_text\":\"ذِكْرُكَ أَخَاكَ بِمَا يَكْرَهُ\",\"citation_type\":\"Hadeeth\"},{\"span_start\":1913,\"span_end\":1959,\"span_text\":\"أَفَرَأَيْتَ إِنْ كَانَ فِي أَخِي مَا أَقُولُ؟\",\"citation_type\":\"Hadeeth\"}]}",
