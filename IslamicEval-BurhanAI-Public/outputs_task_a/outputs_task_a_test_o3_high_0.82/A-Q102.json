      "code": "spans=[]\nfor m in ayahs:\n    idx=m[0]; text=m[1]\n    # trim leading brackets and punctuation per rule\n    trimmed=text.strip()\n    # remove leading decorative marks\n    # Remove leading characters in set:\n    def strip_decor(s):\n        # Remove leading/trailing characters that are punctuation marks or brackets, including ﴿﴾\n        return s.strip('﴿﴾[]()«»\"\\' ,،.;:!?…ـ')\n    span_text=strip_decor(trimmed)\n    # compute new start index\n    start = raw.find(span_text, idx) # may return same idx+1 due to bracket\n    if start==-1:\n        start = raw.index(span_text) # fallback\n    end=start+len(span_text)\n    assert raw[start:end]==span_text\n    spans.append((start,end,span_text))\nspans",
