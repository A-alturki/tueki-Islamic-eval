      "code": "spans = [\n    (\"إِنَّ اللَّهَ يَأْمُرُكُمْ أَنْ تُؤَدُّوا الْأَمَانَاتِ إِلَى أَهْلِهَا\", \"Aya\"),\n    (\"يَا أَيُّهَا الَّذِينَ آمَنُوا اتَّقُوا اللَّهَ وَقُولُوا قَوْلًا سَدِيدًا\", \"Aya\"),\n    (\"وَأَوْفُوا الْكَيْلَ إِذَا كِلْتُمْ وَزِنُوا بِالْقِسْطَاسِ الْمُسْتَقِيمِ ذَٰلِكَ خَيْرٌ وَأَحْسَنُ تَأْوِيلًا\", \"Aya\"),\n    (\"آية المنافق ثلاث: إذا حدث كذب، وإذا وعد أخلف، وإذا اؤتمن خان\", \"Hadeeth\")\n]\n\nresults = []\nfor text, kind in spans:\n    # find all occurrences\n    start = 0\n    while True:\n        idx = raw.find(text, start)\n        if idx == -1:\n            break\n        results.append((idx, idx + len(text), text, kind))\n        start = idx + len(text)\nresults",
