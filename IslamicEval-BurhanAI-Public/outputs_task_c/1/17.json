      "code": "def normalize_ar(text):\n    # remove harakat\n    diacritics = re.compile(r'[\\u064b-\\u0652\\u0670\\u0653-\\u065f\\u06d6-\\u06ed]')\n    text = diacritics.sub('', text)\n    # unify alif variants\n    text = text.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ٱ','ا')\n    text = text.replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\n    # remove tatweel\n    text = text.replace('ـ','')\n    # remove quotes\n    text = text.replace('\"','').replace('«','').replace('»','')\n    return text\n\nsearch_terms = [\"لا تز\",\"لا تزو\",\"لا تزوج\",\"لا تنكح\",\"لا تَزَوَّ\",\"شُرَّع\",\"شرعتك\",\"شرعت\",\"شرعه\",\"شريعتك\",\"شريعه\"]\nmatches=[]\nfor h in hadith:\n    txt = (h.get('hadithTxt') or '') + \" \" + (h.get('Matn') or '')\n    norm = normalize_ar(txt)\n    for term in search_terms:\n        if normalize_ar(term) in norm:\n            matches.append(h)\n            break\nlen(matches)",
