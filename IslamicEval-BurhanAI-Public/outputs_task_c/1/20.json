    {
      "id": "ci_68966606ded481979bec3ff85f1c69280567ab74e1e0ad97",
      "code": "# Helper to strip Arabic diacritics\nHARAKAT = ''.join(chr(c) for c in range(0x0610, 0x061A+1)) + ''.join(chr(c) for c in range(0x064B, 0x065F+1)) + chr(0x0670) + ''.join(chr(c) for c in range(0x06D6,0x06ED+1))\ndef strip_harakat(s):\n    return ''.join(ch for ch in s if ch not in HARAKAT and ch != 'ـ')\ndef normalize_ar(s):\n    s=strip_harakat(s)\n    # normalize different alef forms, ta marbuta vs ha? It's okay to leave.\n    repl = {\n        'أ':'ا','إ':'ا','آ':'ا','ى':'ي','ؤ':'و','ئ':'ي','ٱ':'ا',\n    }\n    return ''.join(repl.get(ch,ch) for ch in s)\n\ndef find_in_hadith(substr):\n    norm = normalize_ar(substr)\n    results=[]\n    for h in hadith:\n        matn = h.get('Matn') or h.get('hadithTxt') or ''\n        if not matn:\n            continue\n        nmatn = normalize_ar(matn)\n        if norm in nmatn:\n            results.append((h['BookID'], h['hadithID'], matn[:150], matn))\n    return results\n\ndef find_contains_words(words):\n    # words: list of strings; check all present\n    norm_words = [normalize_ar(w) for w in words]\n    results=[]\n    for h in hadith:\n        matn = h.get('Matn') or h.get('hadithTxt') or ''\n        if not matn:\n            continue\n        nmatn = normalize_ar(matn)\n        ok=all(w in nmatn for w in norm_words)\n        if ok:\n            results.append((h['BookID'], h['hadithID'], matn))\n    return results",
      "container_id": "cntr_689665e9b3908190842ae3d8497889630f85cb52f8b5cd1c",
      "outputs": null,
      "status": "completed",
      "type": "code_interpreter_call"
    },
