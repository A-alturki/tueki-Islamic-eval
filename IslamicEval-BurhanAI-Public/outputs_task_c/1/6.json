      "id": "ci_689666079f7481969e280333e9d34c4100ca0c174dbd2934",
      "code": "def strip_diacritics(text):\n    # remove Arabic diacritics\n    if text is None:\n        return None\n    diacritics = ''.join(chr(i) for i in range(0x0610, 0x061A+1)) + ''.join(chr(i) for i in range(0x064B, 0x065F+1)) + chr(0x0670) + ''.join(chr(i) for i in range(0x06D6, 0x06ED+1))\n    return re.sub('['+re.escape(diacritics)+']', '', text)\n\ndef search_phrase(phrase):\n    results = []\n    p = strip_diacritics(phrase)\n    for rec in items:\n        for field in ['Matn', 'hadithTxt']:\n            text = rec.get(field)\n            if not text: continue\n            t = strip_diacritics(text)\n            if p in t:\n                results.append((rec['hadithID'], field, text))\n    return results\n\nlen(search_phrase(\"أمك\"))",
