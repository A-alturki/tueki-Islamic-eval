      "id": "ci_689665d71a7c81939d2533928f97c9640ce5674225994833",
      "code": "import re, unicodedata, json, itertools, math\r\n\r\n# function to remove Arabic diacritics\r\narabic_diacritics = re.compile(r'[\\u0610-\\u061a\\u064b-\\u065f\\u06d6-\\u06ed]')\r\ndef normalize(s):\r\n    if s is None:\r\n        return ''\r\n    s = s.replace('ـ','')  # tatweel\r\n    s = arabic_diacritics.sub('', s)\r\n    # normalize ALEF forms\r\n    s = re.sub('[\\u0622\\u0623\\u0625]', 'ا', s)\r\n    s = s.replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\r\n    # remove quotes and brackets\r\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]', ' ', s)  # keep Arabic letters and numbers and underscore\r\n    # collapse whitespace\r\n    s = re.sub(r'\\s+', ' ', s).strip()\r\n    return s\r\n\r\ndef search_keyword(keyword, data, context_window=60):\r\n    key_norm = normalize(keyword)\r\n    results = []\r\n    for item in data:\r\n        text = item.get('Matn') if item.get('Matn') else item.get('hadithTxt','')\r\n        txt_norm = normalize(text)\r\n        if key_norm in txt_norm:\r\n            # find index in txt_norm is not helpful because mapping to original is lost. But we can just capture item.\r\n            results.append(item)\r\n    return results\r\n\r\nquery = \"لا تزوجن شرعتك\"\r\nres = search_keyword(query, hadith_data)\r\nlen(res)",
      "container_id": "cntr_689665be7a608190aecabb33f373737d044612faaae610d6",
