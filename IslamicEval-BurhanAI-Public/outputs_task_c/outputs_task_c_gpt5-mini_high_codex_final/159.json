      "code": "# Define normalization\nimport re\narabic_diacritics = re.compile(\"\"\"[\\u0610-\\u061A\\u064B-\\u065F\\u06D6-\\u06DC\\u06DF-\\u06E8\\u06EA-\\u06ED]\"\"\")\ntatweel = '\\u0640'\n# hamza variants map\nhamza_variants = {\n    'أ':'ا',\n    'إ':'ا',\n    'آ':'ا',\n    'ؤ':'و',\n    'ئ':'ي',\n    'ٱ':'ا',\n}\npunctuation = r'''[!\"#\\$%&'\\(\\)\\*\\+,\\-./:;<=>\\?@\\[\\\\\\]\\^_`{\\|}~،؛؟«»…]'''\n\ndef normalize_ar(text):\n    # remove diacritics\n    text = re.sub(arabic_diacritics, '', text)\n    # remove tatweel\n    text = text.replace(tatweel, '')\n    # normalize hamza variants\n    for k,v in hamza_variants.items():\n        text = text.replace(k,v)\n    # remove punctuation\n    text = re.sub(punctuation,' ', text)\n    # collapse spaces and strip\n    text = re.sub(r'\\s+',' ', text).strip()\n    # lower not needed\n    return text\n\nspan = \"وَإِنَّ مِنْ شِيَعِهِمْ لَوَاحِدَةٌ يَهْدُونَ بِالْحَقِّ وَبَياِنَةً لَهُمْ\"\nnorm_span = normalize_ar(span)\nnorm_span\n",
