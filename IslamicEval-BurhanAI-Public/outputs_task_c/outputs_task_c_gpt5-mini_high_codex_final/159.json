      "code": "from collections import Counter\ndef token_f1(a,b):\n    atoks = a.split()\n    btoks = b.split()\n    a_counter = Counter(atoks)\n    b_counter = Counter(btoks)\n    # intersection count (multiset)\n    inter = sum((a_counter & b_counter).values())\n    if len(atoks)+len(btoks)==0:\n        return 0.0\n    return 2*inter/(len(atoks)+len(btoks))\n\nspan_toks = norm_span.split()\nbest = []\nfor idx,n in enumerate(normalized_ayahs):\n    f1 = token_f1(norm_span, n)\n    best.append((f1, idx, n, qdata[idx]['ayah_text']))\nbest_sorted = sorted(best, key=lambda x: -x[0])\nbest_sorted[:20]\n",
