      "id": "ci_6896756426bc8195bef6b7450e0dee1703a1333a0dd3304e",
      "code": "import re, unicodedata\n\narabic_diacritics = re.compile(r'[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]')\ntatweel_re = re.compile(r'[\\u0640]')\n\ndef normalize_arabic(s):\n    if s is None:\n        return ''\n    s = str(s)\n    # unify hamza forms by mapping to bare alif?\n    # We'll map various alifs to alif\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا')\n    s = s.replace('ى','ي').replace('ئ','ي').replace('ؤ','و').replace('ة','ه')\n    s = tatweel_re.sub('', s)\n    s = arabic_diacritics.sub('', s)\n    # Remove punctuation\n    s = re.sub(r'[^\\w\\s]', ' ', s, flags=re.UNICODE)\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\ndef strip_diacritics(s):\n    return arabic_diacritics.sub('', s)\n\nquery_full = \"صَلِّ عَلَى النَبِيِّ وَعَلَى أَهْلِ بَيْتِهِ\"\nquery_snip = \"صَلِّ عَلَ...ِ بَيْتِهِ\"\nprint(query_full)",
