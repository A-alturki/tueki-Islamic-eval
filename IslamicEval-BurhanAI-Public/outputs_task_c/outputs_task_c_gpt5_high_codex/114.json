      "id": "ci_689675b945588195973f4b9746fb791103a1333a0dd3304e",
      "code": "def lcs_length(a,b):\n    # dynamic programming\n    n, m = len(a), len(b)\n    dp = [0]*(m+1)\n    for i in range(1,n+1):\n        prev=0\n        for j in range(1,m+1):\n            tmp=dp[j]\n            if a[i-1]==b[j-1]:\n                dp[j]=prev+1\n            else:\n                dp[j]=max(dp[j], dp[j-1])\n            prev=tmp\n    return dp[m]\n\nq_norm = normalize_arabic(query_full)\ncand_norm = normalize_arabic(cand_3356_text)\nlcs = lcs_length(q_norm, cand_norm)\nlen_q = len(q_norm); len_c = len(cand_norm)\nratio_q = lcs/len_q\nratio_max = lcs / max(len_q, len_c)\nratio_avg = 2*lcs/(len_q+len_c)\nlen_q, len_c, lcs, ratio_q, ratio_max, ratio_avg",
      "container_id": "cntr_68967535f3f8819096ff94217251f54f021cf2394c76e88c",
