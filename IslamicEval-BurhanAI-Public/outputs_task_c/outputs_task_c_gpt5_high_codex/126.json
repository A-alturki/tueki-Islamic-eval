      "id": "ci_6896755ef2ac819698e42d9792a84b570668a5a0450849fd",
      "code": "arabic_diacritics = re.compile(r'[\\u0610-\\u061A\\u064B-\\u065F\\u06D6-\\u06ED]')\ntatweel_re = re.compile(r'[\\u0640]')\npunc_re = re.compile(r'[^\\w\\s\\u0600-\\u06FF]')  # remove non-word but keep Arabic\nspace_re = re.compile(r'\\s+')\n\ndef normalize_ar(text, unify_alef=True, unify_yaa=True, unify_taa_marbuta=False, remove_punc=True):\n    if text is None:\n        return ''\n    t = text\n    t = arabic_diacritics.sub('', t)\n    t = tatweel_re.sub('', t)\n    # unify hamza/alef\n    if unify_alef:\n        t = re.sub('[\\u0622\\u0623\\u0625\\u0671]', 'ا', t)  # آأإٱ -> ا\n        t = t.replace('ٮ','ب')  # not relevant\n    # unify yaa\n    if unify_yaa:\n        t = t.replace('ي', 'ي')  # no-op\n        t = t.replace('ى', 'ي')\n        t = t.replace('ئ', 'ي')\n    # unify waw hamza\n    t = t.replace('ؤ', 'و')\n    # optional: taa marbuta\n    if unify_taa_marbuta:\n        t = t.replace('ة', 'ه')\n    # remove punctuation\n    if remove_punc:\n        t = punc_re.sub(' ', t)\n    # lowercase?\n    # collapse whitespace\n    t = space_re.sub(' ', t).strip()\n    return t\n\ndef token_set(text):\n    return set(normalize_ar(text).split())\n\nquery_full = \"إِنَّ الدَينَ يُتَضاعَفُ لِلَّذينَ يُدَبِّرُونَهُ\"\nquery_snippet = \"إِنَّ الدَ...بِّرُونَهُ\"  # not useful, we'll ignore the ellipsis; we should search using the substring that equals \"إِنَّ الدَينَ يُتَضاعَفُ لِلَّذينَ يُدَبِّرُونَهُ\"\nprint(normalize_ar(query_full))",
