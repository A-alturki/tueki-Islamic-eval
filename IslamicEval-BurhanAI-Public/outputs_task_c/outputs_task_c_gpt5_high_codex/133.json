      "code": "def best_matches_in_hadith(full_span, topn=20, field='Matn'):\r\n    ns = norm(full_span)\r\n    scores = []\r\n    for h in hadith:\r\n        t = h.get(field)\r\n        if not t:\r\n            continue\r\n        r = SequenceMatcher(None, normalize_arabic(t), ns).ratio()\r\n        scores.append((r, t, h))\r\n    scores.sort(reverse=True, key=lambda x: x[0])\r\n    return scores[:topn]\r\n\r\ntop_matn = best_matches_in_hadith(full_span, topn=10, field='Matn')\r\nfor r, t, h in top_matn:\r\n    print(r, \"\\n\", t, \"\\n----\")",
