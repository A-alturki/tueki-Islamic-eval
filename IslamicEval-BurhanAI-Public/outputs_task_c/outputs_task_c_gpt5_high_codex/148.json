      "id": "ci_6896754ec0788193a3ed98a5af91c72e01b638a4bf8ead47",
      "code": "import re, unicodedata\r\n\r\ndef normalize_arabic(s):\r\n    # strip tashkeel\r\n    arabic_diacritics = re.compile(r'[\\u0617-\\u061A\\u064B-\\u0652\\u0657-\\u065F\\u0670\\u06D6-\\u06ED]')\r\n    s = arabic_diacritics.sub('', s)\r\n    # tatweel, punctuation marks to space\r\n    s = re.sub(r'[\\u0640]', '', s)  # tatweel\r\n    # unify hamza forms\r\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\r\n    # remove punctuation and non-letters/digits\r\n    s = re.sub(r'[^\\w\\s]', ' ', s, flags=re.UNICODE)\r\n    # collapse spaces\r\n    s = re.sub(r'\\s+', ' ', s).strip()\r\n    return s.lower()\r\n\r\nspan = \"كتاب أنزلناه إليك مبارك ليدبروا آلاءه وليتذكر أولو الألباب\"\r\ncandidate = [m for m in matches if m[0]==38 and m[1]==29][0][2]\r\nnorm_span = normalize_arabic(span)\r\nnorm_candidate = normalize_arabic(candidate)\r\nnorm_span, norm_candidate",
