      "id": "ci_68967558e9fc819389db9b2c4cc380d001b638a4bf8ead47",
      "code": "def lcs_length(a, b):\r\n    # compute length of LCS for sequences (characters)\r\n    n, m = len(a), len(b)\r\n    dp = [0]*(m+1)\r\n    for i in range(1, n+1):\r\n        prev = 0\r\n        for j in range(1, m+1):\r\n            temp = dp[j]\r\n            if a[i-1]==b[j-1]:\r\n                dp[j] = prev + 1\r\n            else:\r\n                dp[j] = max(dp[j], dp[j-1])\r\n            prev = temp\r\n    return dp[m]\r\n\r\ndef similarity(a, b):\r\n    a_norm = normalize_arabic(a)\r\n    b_norm = normalize_arabic(b)\r\n    lcs = lcs_length(a_norm, b_norm)\r\n    denom = 0.5*(len(a_norm)+len(b_norm))\r\n    if denom==0:\r\n        return 0.0\r\n    return lcs/denom\r\n\r\norig_span = \"كتاب أنزلناه إليك مبارك ليدبروا آلاءه وليتذكر أولو الألباب\"\r\ncandidate = cand_text\r\nsim = similarity(orig_span, candidate)\r\nlen(normalize_arabic(orig_span)), len(normalize_arabic(candidate)), sim",
