    {
      "id": "ci_6896757534188190b1fbec666070d70009fb5281343138ef",
      "code": "def normalize_ar(s):\n    # Remove diacritics, tatweel, punctuation; normalize hamza; lowercase; collapse spaces\n    s = s.replace('\\u0640', '')  # tatweel\n    # unify hamza forms? We'll map various alef forms to bare alif.\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ۀ','ه')\n    # Remove tashkeel diacritics\n    diacritics = ''.join(chr(c) for c in range(0x0610, 0x061B+1)) + ''.join(chr(c) for c in range(0x064B, 0x065F+1)) + ''.join(chr(c) for c in range(0x0670, 0x0670+1)) + ''.join(chr(c) for c in range(0x06D6, 0x06ED+1))\n    s = ''.join(ch for ch in s if ch not in diacritics)\n    # Remove punctuation\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]+', ' ', s)\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\ntarget = \"أربعة أشهر وعشرا\"\nhits = []\nfor rec in quran_db:\n    if normalize_ar(target) in normalize_ar(rec['ayah_text']):\n        hits.append((rec['surah_id'], rec['ayah_id'], rec['ayah_text']))\nhits[:5], len(hits)",
      "container_id": "cntr_68967539c01c8190ab91a91e2bb33d110ec89d068958b2b3",
