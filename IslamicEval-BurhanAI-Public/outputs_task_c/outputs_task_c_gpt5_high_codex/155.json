    {
      "id": "ci_68967580e93481909bc5b3bbd788e1ba09fb5281343138ef",
      "code": "def token_f1(a,b):\n    na = normalize_ar(a).split()\n    nb = normalize_ar(b).split()\n    sa, sb = set(na), set(nb)\n    inter = sa & sb\n    if not sa and not sb:\n        return 1.0\n    if not sa or not sb:\n        return 0.0\n    prec = len(inter)/len(sa)\n    rec = len(inter)/len(sb)\n    if prec+rec==0:\n        f1 = 0.0\n    else:\n        f1 = 2*prec*rec/(prec+rec)\n    return f1, prec, rec, inter, sa, sb\n\ntoken_f1(orig, cand)",
