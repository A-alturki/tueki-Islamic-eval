      "code": "def lcs_length(a, b):\n    # compute LCS length for sequences of tokens or characters? We'll use characters on normalized string.\n    n, m = len(a), len(b)\n    dp = [0] * (m+1)\n    for i in range(1, n+1):\n        prev = 0\n        for j in range(1, m+1):\n            tmp = dp[j]\n            if a[i-1] == b[j-1]:\n                dp[j] = prev + 1\n            else:\n                dp[j] = max(dp[j], dp[j-1])\n            prev = tmp\n    return dp[m]\n\ndef sim_score(a, b):\n    # normalized lcs to min length e.g., LCS divided by max(len(a), len(b)) or by average? The instruction suggests robust.\n    a_norm = normalize_arabic(a)\n    b_norm = normalize_arabic(b)\n    l = lcs_length(a_norm, b_norm)\n    return l / max(len(a_norm), len(b_norm))\n\norig = original_full\ncands = candidates\ndef score_for(v):\n    return sim_score(original_full, v['ayah_text'])\nscores = sorted([(score_for(v), v) for v in quran], key=lambda x: x[0], reverse=True)\nscores[:10]",
