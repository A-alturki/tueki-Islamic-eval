      "id": "ci_6896755bc03c81969dc23e05870a580301bfa0a61e7b7ecd",
      "code": "import re\n# Arabic diacritics\narabic_diacritics = re.compile(r'[\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]') # tashkeel and Quranic annotation marks\ntatweel_re = re.compile(r'\\u0640')\npunc_re = re.compile(r'[^\\w\\s\\u0600-\\u06FF]')  # remove punctuation except Arabic letters/digits/underscore\nspace_re = re.compile(r'\\s+')\n\ndef normalize_arabic(s):\n    if not isinstance(s, str):\n        return \"\"\n    s = s.strip()\n    # unify alifs\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ٱ','ا')\n    s = s.replace('ى','ي') # unify alef maqsura to ya\n    s = s.replace('ؤ','و').replace('ئ','ي')\n    s = tatweel_re.sub('', s)\n    s = arabic_diacritics.sub('', s)\n    s = punc_re.sub(' ', s)\n    s = space_re.sub(' ', s)\n    return s.strip().lower()\n\ndef strip_diacritics_only(s):\n    return arabic_diacritics.sub('', s)\n\ndef token_set(s):\n    return set(normalize_arabic(s).split())\n",
