    {
      "id": "ci_6896755204a88195848b9bdc8ba356ec0b33768551d56d64",
      "code": "import re, unicodedata\n\ndef normalize_arabic(s):\n    if s is None:\n        return \"\"\n    # remove diacritics\n    s = ''.join(c for c in unicodedata.normalize('NFKD', s) if not unicodedata.combining(c))\n    # remove tatweel\n    s = s.replace('ـ', '')\n    # normalize hamza variants\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ء','')\n    # normalize ta marbuta?\n    s = s.replace('ة','ه')\n    # Arabic punctuation or extra marks\n    s = re.sub(r'[^\\w\\s]+', ' ', s)\n    # Arabic digits to ascii?\n    ar_digits = '٠١٢٣٤٥٦٧٨٩'\n    en_digits = '0123456789'\n    trans = str.maketrans(ar_digits, en_digits)\n    s = s.translate(trans)\n    # lowercase (not relevant)\n    s = s.lower()\n    # collapse whitespace\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\norig_span = \"وَلَقَدْ أَرْسَلْنَا إِلَى أُمَمٍ مِن قَبْلِكَ فَأَخَذْنَا عَلَيْهِمُ الْعَذَابَ فَهَلْ يَتَذَكَّرُونَ\"\nnorm_span = normalize_arabic(orig_span)\nnorm_span",
      "container_id": "cntr_6896753634948190895aee8703e173da0b2d9b159650a304",
      "outputs": null,
      "status": "completed",
      "type": "code_interpreter_call"
