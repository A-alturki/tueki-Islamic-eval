      "id": "ci_689675625e3c819594533c19082a94720b33768551d56d64",
      "code": "def lcs(a,b):\n    # normalized LCS length / max length\n    A = normalize_arabic(a)\n    B = normalize_arabic(b)\n    # compute LCS length dynamic programming\n    n,m = len(A), len(B)\n    dp = [0]*(m+1)\n    for i in range(1,n+1):\n        prev = 0\n        for j in range(1,m+1):\n            tmp = dp[j]\n            if A[i-1]==B[j-1]:\n                dp[j] = prev+1\n            else:\n                if dp[j] < dp[j-1]:\n                    dp[j] = dp[j-1]\n            prev = tmp\n    l = dp[m]\n    return l/max(n,m) if max(n,m)>0 else 0.0\n\ncandidate = cand[0]['ayah_text']\nscore = lcs(orig_span, candidate)\nscore",
