      "id": "ci_68967549412c8196add55f762f4afede07385389a0eb14ed",
      "code": "import regex as re\n\nAR_DIAC = re.compile(r\"[\\p{Mn}ـ]\")  # remove diacritics + tatweel\ndef normalize_ar(s):\n    if s is None:\n        return \"\"\n    s = str(s)\n    # Remove Arabic diacritics and tatweel\n    s = AR_DIAC.sub(\"\", s)\n    # Normalize hamza forms\n    s = s.replace(\"أ\",\"ا\").replace(\"إ\",\"ا\").replace(\"أ\",\"ا\").replace(\"ؤ\",\"و\").replace(\"ئ\",\"ي\").replace(\"ء\",\"\")\n    # Normalize taa marbuta to ha? Usually keep\n    # Keep ta marbuta as ه? Some normalizations do; but I'll keep as ة->ه? For now leave\n    s = s.replace(\"ة\",\"ه\")\n    # Remove punctuation and non letters/digits/spaces\n    s = re.sub(r\"[^\\p{L}\\p{Nd}\\s]\", \" \", s)\n    # Collapse spaces\n    s = re.sub(r\"\\s+\", \" \", s).strip()\n    return s\n\ndef prep_db_text(s):\n    return normalize_ar(s)\n\n# Extract hadith matn field\ndef get_matn(rec):\n    # There might be fields 'Matn' or 'hadithTxt'\n    if isinstance(rec, dict):\n        for k in ['Matn', 'hadithTxt', 'matn', 'HadithText', 'hadithtext']:\n            if k in rec and rec[k]:\n                return str(rec[k])\n    return \"\"\n\nnorm_query = normalize_ar(\"لا تَزَوَّجَنَّ شُرَّعَتكَ\")\nnorm_query",
      "container_id": "cntr_6896753629d08190a8fd357fd94638e407fb134b8e66f5e4",
