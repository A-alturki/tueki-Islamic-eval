      "id": "ci_6896759b2cb48196b8ce04324c128b4207385389a0eb14ed",
      "code": "from difflib import SequenceMatcher\n\ndef similarity(a,b):\n    return SequenceMatcher(None, a, b).ratio()\n\nquery = prep_db_text(\"لا تزوجن شرعتك\")\n# Evaluate on hadith and quran\nbest_hadith = []\nfor i, matn, norm in hadith_texts:\n    r = similarity(query, norm)\n    if r > 0.7:\n        best_hadith.append((r,i,matn))\nbest_hadith = sorted(best_hadith, reverse=True)[:20]\nlen(best_hadith), best_hadith[:3]",
