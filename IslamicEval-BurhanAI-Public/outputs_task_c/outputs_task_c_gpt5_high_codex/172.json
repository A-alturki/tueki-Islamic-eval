      "id": "ci_68967562f5d081939bd5a733d9c61ac401073fba4ee57f54",
      "code": "def normalize(s):\n    if not s: return ''\n    # remove tashkeel, tatweel, punctuation, unify alif/hamza\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]+', ' ', s)  # remove punctuation except arabic letters and digits and whitespace\n    # remove arabic diacritics\n    arabic_diacritics = re.compile(r'[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06DC\\u06DF-\\u06E8\\u06EA-\\u06ED]')\n    s = re.sub(arabic_diacritics, '', s)\n    s = s.replace('ـ', '')  # tatweel\n    # unify alef forms\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ة','ه').replace('ى','ي')\n    # lowercase not applicable; just collapse spaces\n    s = re.sub(r'\\s+',' ', s).strip()\n    return s\n\ndef search_normalized(snippet, fields=['hadithTxt','Matn'], print_samples=5):\n    n = normalize(snippet)\n    res=[]\n    for rec in hadith_db:\n        for field in fields:\n            text = rec.get(field) or ''\n            if n and normalize(text).find(n) != -1:\n                res.append((rec['hadithID'], field, text))\n                break\n    return res\n\nsnippet = \"أَلاَ تَغَرَّضوا بِالنِسَاءِ وَلاَ تَجَشَّموا بِهِنَّ\"\nlen(snippet), normalize(snippet)[:200], normalize(snippet)",
