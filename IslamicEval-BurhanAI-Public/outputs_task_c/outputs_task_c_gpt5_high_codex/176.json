      "code": "def remove_diacritics(text):\n    # remove Arabic diacritics\n    arabic_diacritics = re.compile(r'[\\u0617-\\u061A\\u064B-\\u0652\\u0654\\u0655\\u0670\\u06D6-\\u06ED]')\n    text = arabic_diacritics.sub('', text)\n    # remove tatweel\n    text = text.replace('ـ','')\n    return text\n\ndef normalize_arabic(text):\n    # unify hamza forms and normalize alif, ta marbuta if needed\n    text = remove_diacritics(text)\n    text = re.sub(r'[إأآا]', 'ا', text)\n    text = re.sub(r'ى', 'ي', text)\n    text = re.sub(r'ؤ', 'و', text)\n    text = re.sub(r'ئ', 'ي', text)\n    text = re.sub(r'ة', 'ه', text)\n    text = re.sub(r'ٱ', 'ا', text)\n    text = re.sub(r'[^ء-ي0-9 ]+', ' ', text)\n    text = re.sub(r'\\s+', ' ', text).strip()\n    return text\n\norig_span = \"وَإِذْ أَنْذَرْنَا قَوْمَ شُعَيْبٍ\"\nsnippet = \"وَإِذْ أَن...َ شُعَيْبٍ\"\nprint(orig_span)\nprint(normalize_arabic(orig_span))",
