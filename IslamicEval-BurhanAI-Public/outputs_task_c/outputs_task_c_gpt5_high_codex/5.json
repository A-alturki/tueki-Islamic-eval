      "id": "ci_6896757ffd00819394a04d2aab43c1e40fe89b90ef7e5af0",
      "code": "import re\r\n\r\n# Arabic diacritics\r\narabic_diacritics = re.compile(r'[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06DC\\u06DF-\\u06E8\\u06EA-\\u06ED]')\r\n\r\ndef normalize_ar(text):\r\n    if text is None:\r\n        return ''\r\n    # Remove diacritics\r\n    text = arabic_diacritics.sub('', text)\r\n    # Remove tatweel\r\n    text = text.replace('ـ', '')\r\n    # Normalize hamza forms\r\n    text = text.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ء','')\r\n    # Normalize ya/aleph maqsura\r\n    text = text.replace('ى','ي')\r\n    # Teh marbuta to ha? maybe keep\r\n    # Remove punctuation (Arabic and English) and digits\r\n    text = re.sub(r'[^\\u0600-\\u06FF\\s]', ' ', text)\r\n    # Collapse multiple spaces\r\n    text = re.sub(r'\\s+', ' ', text).strip()\r\n    return text\r\n\r\n# Prepare text list\r\nhadith_texts = []\r\nfor h in hadith_data:\r\n    txt = h.get('Matn') or h.get('hadithTxt') or ''\r\n    hadith_texts.append((txt, h))\r\n\r\n# Search for \"لا زواج\" exact or normalized\r\nquery = \"لا زواجَ لِأُمَّةٍ\"\r\nnorm_query = normalize_ar(query)\r\nnorm_query\n",
