      "id": "ci_689675d0cdc881939a904effafb92e3b0fe89b90ef7e5af0",
      "code": "def lcs_length(a, b):\r\n    # DP LCS length\r\n    # Keep memory small since strings short\r\n    n, m = len(a), len(b)\r\n    dp = [0]*(m+1)\r\n    for i in range(1, n+1):\r\n        prev = 0\r\n        for j in range(1, m+1):\r\n            tmp = dp[j]\r\n            if a[i-1] == b[j-1]:\r\n                dp[j] = prev + 1\r\n            else:\r\n                dp[j] = max(dp[j], dp[j-1])\r\n            prev = tmp\r\n    return dp[m]\r\n\r\ndef sim_ratio(a, b):\r\n    # compute normalized LCS over max length\r\n    la, lb = len(a), len(b)\r\n    if la == 0 or lb == 0:\r\n        return 0.0\r\n    lcs = lcs_length(a, b)\r\n    return lcs / max(la, lb)\r\n\r\nratio1 = sim_ratio(o, c1)\r\nratio2 = sim_ratio(o, c2)\r\n\r\nratio1, ratio2\n",
      "container_id": "cntr_6896753664ec8190b92eba449052d34c04590b305da53ceb",
