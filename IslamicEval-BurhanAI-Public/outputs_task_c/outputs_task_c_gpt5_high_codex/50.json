      "id": "ci_68967574d4e481938c4e04dd0dcd788107972a11f60545f8",
      "code": "import unicodedata, re\n\norig = \"فَأُمُّهُ هِيَ الْهَاوِيَةُ\"\ncand = \"فَأُمُّهُ هَاوِيَةٌ\"\ndef normalize(s):\n    # remove diacritics (tashkeel)\n    s = ''.join(ch for ch in s if not unicodedata.category(ch).startswith('M'))\n    # remove tatweel\n    s = s.replace('ـ', '')\n    # unify hamza? keep for now\n    # remove punctuation\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]+', '', s)\n    # collapse spaces\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\ndef lcs(a, b):\n    # compute length of LCS\n    m, n = len(a), len(b)\n    dp = [ [0]*(n+1) for _ in range(m+1)]\n    for i in range(m):\n        for j in range(n):\n            if a[i]==b[j]:\n                dp[i+1][j+1] = dp[i][j]+1\n            else:\n                dp[i+1][j+1] = max(dp[i][j+1], dp[i+1][j])\n    return dp[m][n]\no = normalize(orig)\nc = normalize(cand)\no, c, len(o), len(c), lcs(o,c), lcs(o,c)/max(len(o),len(c))",
