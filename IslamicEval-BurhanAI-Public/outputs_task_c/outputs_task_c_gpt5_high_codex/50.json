      "code": "def normalize_words(s):\n    s = ''.join(ch for ch in s if not unicodedata.category(ch).startswith('M'))\n    s = s.replace('ـ', '')\n    s = re.sub(r'[^\\s\\u0600-\\u06FF]+', ' ', s)  # remove punctuation, keep arabic letters and spaces\n    s = re.sub(r'\\s+', ' ', s).strip()\n    words = s.split()\n    # unify hamza forms by normalizing \"أإآاىي\" ??? keep simple\n    # strip 'ال' prefix\n    def strip_al(w):\n        if w.startswith('ال'):\n            return w[2:]\n        return w\n    words = [strip_al(w) for w in words]\n    return words\now = normalize_words(orig)\ncw = normalize_words(cand)\now, cw",
