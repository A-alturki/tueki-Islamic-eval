      "id": "ci_6896755929848197af64e6e438e73fae032280f8038bb35a",
      "code": "def norm_ar(s):\n    # Normalize Arabic: remove diacritics, tatweel, punctuation, unify hamza\n    if s is None:\n        return ''\n    # remove tashkeel\n    tashkeel = ''.join(chr(c) for c in range(0x600, 0x700) if unicodedata.category(chr(c)) in ('Mn',))\n    # But better remove explicit diacritics:\n    diacritics = re.compile(r'[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]')\n    s = diacritics.sub('', s)\n    # remove tatweel\n    s = s.replace('ـ', '')\n    # unify hamza variants\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ى','ي')\n    # normalize spaces and punctuation\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]', ' ', s)  # remove punctuation\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\ndef search_quran_by_phrase(phrase):\n    n = norm_ar(phrase)\n    res=[]\n    for rec in qdb:\n        t = rec['ayah_text']\n        if norm_ar(t).find(n) != -1:\n            res.append(rec)\n    return res\n\ndef search_quran_contains_all(tokens):\n    tokens_n = [norm_ar(t) for t in tokens]\n    res=[]\n    for rec in qdb:\n        tn = norm_ar(rec['ayah_text'])\n        if all(tok in tn for tok in tokens_n):\n            res.append(rec)\n    return res\n\ndef search_hadith_by_phrase(phrase):\n    n = norm_ar(phrase)\n    res=[]\n    for rec in hdb:\n        t = rec.get('hadithTxt') or \"\"\n        t2 = rec.get('Matn') or \"\"\n        if (t and norm_ar(t).find(n)!=-1) or (t2 and norm_ar(t2).find(n)!=-1):\n            res.append(rec)\n    return res\n\ndef similarity(a,b):\n    a = norm_ar(a)\n    b = norm_ar(b)\n    if not a or not b:\n        return 0.0\n    sm = difflib.SequenceMatcher(a=a,b=b)\n    return sm.ratio()\n\nphrase = \"من طين\"\ncandidates = search_quran_by_phrase(phrase)\nlen(candidates)",
      "container_id": "cntr_68967535e3508190909b1f7a92eb14d80ec97a191623c29a",
