      "code": "def strip_diacritics(s):\n    # Remove Arabic diacritics and tatweel. Also unify hamza forms by normalizing to bare alif?\n    # We'll implement: remove combining marks and tatweel, standardize alef-hamza to alif\n    s = s.replace(\"ـ\", \"\")  # tatweel\n    # unify hamza forms: أإآٱ to ا\n    s = s.replace(\"أ\", \"ا\").replace(\"إ\", \"ا\").replace(\"آ\", \"ا\").replace(\"ٱ\", \"ا\")\n    # unify ta marbuta and ha? maybe not\n    # unify ye? ى to ي for search\n    s = s.replace(\"ى\", \"ي\").replace(\"ؤ\", \"و\").replace(\"ئ\", \"ي\")\n    # remove diacritics\n    return ''.join(ch for ch in unicodedata.normalize('NFD', s) if not unicodedata.combining(ch))\n\ndef normalize(s):\n    s = strip_diacritics(s)\n    # remove punctuation and non-letters\n    # Keep Arabic letters and spaces\n    s = re.sub(r\"[^\\u0600-\\u06FF\\s]\", \" \", s)\n    # collapse whitespace\n    s = \" \".join(s.split())\n    return s\n\n# Search for verses containing 'من روحه'\nmatches = []\nfor v in quran_data:\n    txt = v.get(\"ayah_text\", \"\")\n    if \"من روحه\" in strip_diacritics(txt):\n        matches.append(v)\n\nlen(matches)",
