      "code": "from difflib import SequenceMatcher\n\ndef ratio(a,b):\n    return SequenceMatcher(a=a,b=b).ratio()\n\ndef token_f1(a,b):\n    ta = normalize_ar(a).split()\n    tb = normalize_ar(b).split()\n    sa, sb = set(ta), set(tb)\n    if not sa and not sb:\n        return 1.0\n    if not sa or not sb:\n        return 0.0\n    inter = sa & sb\n    prec = len(inter)/len(sa) if sa else 0.0\n    rec = len(inter)/len(sb) if sb else 0.0\n    if prec+rec==0: return 0.0\n    return 2*prec*rec/(prec+rec)\n\ndef combined_sim(a,b):\n    return 0.5*ratio(normalize_ar(a), normalize_ar(b)) + 0.5*token_f1(a,b)\n",
