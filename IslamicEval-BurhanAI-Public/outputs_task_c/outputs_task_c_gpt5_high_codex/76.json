      "code": "import unicodedata, re, math, difflib, itertools, json, os, sys\n\norig = \"وَمَنْ يَتَّقِ اللهَ يَجْعَلْ لَهُ مَخْرَجًا وَيَرْزُقْهُ مِنْ حَيْثُ لاَ يَحْتَسِبُ\"\ndef normalize_ar(s):\n    # remove diacritics including tashkeel signs and small marks\n    # unify different alef forms, hamza, ya -> alif maqsura?\n    # Remove tatweel\n    s = s.replace('ٱ','ا') # Alif with wasla\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا')\n    s = s.replace('ى','ي')  # unify alif maqsura to ya\n    s = s.replace('ة','ه')  # maybe unify?\n    # remove diacritics marks\n    # Diacritics range: \\u064b-\\u065f and others like \\u06d6-\\u06ed\n    s = re.sub(r'[\\u064b-\\u065f\\u06d6-\\u06ed]', '', s)\n    # remove tatweel\n    s = s.replace('ـ','')\n    # remove punctuation, stop signs like ۗۙۛۚ etc in arabic block\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]', ' ', s)\n    # collapse whitespace\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\ndef lcs(a,b):\n    # compute length of LCS\n    # dynamic programming with O(n*m) maybe heavy, but strings small\n    n, m = len(a), len(b)\n    dp = [0]*(m+1)\n    for i in range(1, n+1):\n        prev = 0\n        for j in range(1, m+1):\n            temp = dp[j]\n            if a[i-1]==b[j-1]:\n                dp[j] = prev + 1\n            else:\n                dp[j] = max(dp[j], dp[j-1])\n            prev = temp\n    return dp[m]\n\ndef lcs_ratio(a,b):\n    # normalized by max length\n    L = lcs(a,b)\n    return L / max(1, max(len(a), len(b)))\n\ndef token_f1(a,b):\n    ta = a.split()\n    tb = b.split()\n    set_a = set(ta)\n    set_b = set(tb)\n    inter = len(set_a & set_b)\n    if inter==0:\n        return 0.0\n    p = inter/len(set_a)\n    r = inter/len(set_b)\n    if p+r==0: return 0.0\n    return 2*p*r/(p+r)\n\norig_norm = normalize_ar(orig)\norig_norm",
