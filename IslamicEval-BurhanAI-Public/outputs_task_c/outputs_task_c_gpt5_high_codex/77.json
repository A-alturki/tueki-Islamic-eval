      "id": "ci_689675d344908194b2b671e9257fe1e80ada470304bdfb4d",
      "code": "# compute LCS length\ndef lcs_length(a, b):\n    # dynamic programming\n    n, m = len(a), len(b)\n    dp = [0]*(m+1)\n    for i in range(1,n+1):\n        prev = 0\n        ai = a[i-1]\n        for j in range(1,m+1):\n            tmp = dp[j]\n            if ai == b[j-1]:\n                dp[j] = prev + 1\n            else:\n                dp[j] = max(dp[j], dp[j-1])\n            prev = tmp\n    return dp[m]\n\ndef lcs_ratio(a, b):\n    L = lcs_length(a, b)\n    return L / max(len(a), len(b))\n\nratio = lcs_ratio(s1n, s2n)\nL = lcs_length(s1n, s2n)\nlen1, len2 = len(s1n), len(s2n)\nL, len1, len2, ratio",
