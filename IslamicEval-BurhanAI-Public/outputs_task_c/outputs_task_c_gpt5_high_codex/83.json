      "code": "import unicodedata, re\n\ndef normalize_arabic(s):\n    if s is None:\n        return None\n    # remove tatweel and diacritics\n    s = re.sub(r'[\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]', '', s) # Harakat range and some Quranic marks\n    # remove tatweel\n    s = s.replace('ـ','')\n    # Replace Arabic specific punctuation and unify hamza forms? We'll unify alef variants.\n    # Convert to NFC\n    s = unicodedata.normalize('NFKC', s)\n    # unify alef forms\n    s = re.sub('[\\u0622\\u0623\\u0625\\u0671\\u0672\\u0673\\u0675]', 'ا', s)\n    # unify ya/alef maqsura\n    s = s.replace('ى','ي')\n    # unify taa marbuta to ha? Keep as taa marbuta maybe not necessary.\n    # remove punctuation/stop signs\n    s = re.sub(r'[^\\u0600-\\u06FF0-9 ]+', ' ', s)  # keep Arabic letters and digits and space\n    s = re.sub(r'\\s+',' ', s).strip()\n    return s\n\norig = \"ولقد أرسلنا شعيبًا إلى قومه فقال يا قوم اعبدوا الله ما لكم من إله غيره قد جاءتكم بينة من ربكم فأوفوا الكيل والميزان ولا تبخسوا الناس أشياءهم ولا تفسدوا في الأرض بعد إصلاحها ذلكم خير لكم إن كنتم مؤمنين\"\ncand = ayah_7_85\n\nnorm_orig = normalize_arabic(orig)\nnorm_cand = normalize_arabic(cand)\nnorm_orig, norm_cand, len(norm_orig), len(norm_cand)",
