      "code": "def norm_ar(s):\n    if s is None:\n        return \"\"\n    # remove diacritics and tatweel\n    s = re.sub(r'[\\u064B-\\u065F\\u0610-\\u061A\\u06D6-\\u06ED\\u0670\\u0640]', '', s)\n    # normalize hamza forms\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا')\n    s = s.replace('ؤ','و').replace('ئ','ي').replace('ء','')\n    # normalize taa marbuta and alif maqsurah\n    s = s.replace('ة','ه').replace('ى','ي')\n    # remove punctuation and non-letters/digits spaces\n    s = re.sub(r'[^\\u0621-\\u063A\\u0641-\\u0669a-zA-Z0-9\\s]', ' ', s)\n    # collapse spaces\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\n# build index\nhadith_texts = []\nfor h in hadith_data:\n    matn = h.get('Matn') or ''\n    had = h.get('hadithTxt') or ''\n    combined = matn if matn else had\n    hadith_texts.append((combined, h))\nlen(hadith_texts)",
