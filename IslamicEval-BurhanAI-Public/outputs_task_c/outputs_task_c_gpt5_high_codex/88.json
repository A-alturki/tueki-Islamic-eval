      "id": "ci_689675dcd21c8193a33485d93dafc709037376bf98a1199b",
      "code": "def token_f1(a,b):\n    ta = a.split()\n    tb = b.split()\n    sa, sb = set(ta), set(tb)\n    inter = sa & sb\n    if not sa and not sb:\n        return 0.0\n    return 2*len(inter)/(len(sa)+len(sb))\n\ndef sim_score(a, b):\n    # combined measure\n    a=norm_ar(a); b=norm_ar(b)\n    r = difflib.SequenceMatcher(a=a, b=b).ratio()\n    tf1 = token_f1(a,b)\n    # combine with weights\n    return 0.5*r + 0.5*tf1, r, tf1\n\n# Compute top 30\nscores = []\nfor txt,h in hadith_texts:\n    s, r, tf1 = sim_score(orig, txt)\n    scores.append((s, r, tf1, txt, h))\nscores.sort(reverse=True, key=lambda x: x[0])\nscores[:5]",
