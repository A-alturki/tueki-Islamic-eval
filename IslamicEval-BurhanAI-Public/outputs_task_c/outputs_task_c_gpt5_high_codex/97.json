      "id": "ci_6896756d215081939823e31d47f4162009994c93beb0d5f7",
      "code": "import re, unicodedata\n\nAR_DIACRITICS = ''.join([chr(x) for x in range(0x0610, 0x061A+1)]) + ''.join([chr(x) for x in range(0x064B, 0x065F+1)]) + ''.join([chr(x) for x in range(0x0670, 0x0670+1)]) + ''.join([chr(x) for x in range(0x06D6, 0x06ED+1)])\ndef normalize_ar(s):\n    if s is None: return None\n    s = ''.join(ch for ch in s if ch not in AR_DIACRITICS)\n    s = s.replace('ـ','') # tatweel\n    # unify alef forms\n    s = re.sub('[إأٱآا]', 'ا', s)\n    # unify yaa/aleph maqsura\n    s = s.replace('ى','ي')\n    # unify taa marbuta to ha? Might just keep ة to ه? But we might convert both to 'ه' to help.\n    s = s.replace('ة','ه')\n    # remove punctuation\n    s = re.sub(r'[^\\u0600-\\u06FF0-9 ]+', ' ', s)  # keep Arabic letters, digits, space\n    s = re.sub(r'\\s+', ' ', s).strip().lower()\n    return s\n\ndef lcs_length(a, b):\n    # dynamic programming O(n*m) fairly small texts\n    n, m = len(a), len(b)\n    dp = [0]*(m+1)\n    for i in range(1, n+1):\n        prev = 0\n        ai = a[i-1]\n        for j in range(1, m+1):\n            temp = dp[j]\n            if ai == b[j-1]:\n                dp[j] = prev + 1\n            else:\n                if dp[j] < dp[j-1]:\n                    dp[j] = dp[j-1]\n            prev = temp\n    return dp[m]\n\ndef sim_ratio(a, b):\n    a_n = normalize_ar(a)\n    b_n = normalize_ar(b)\n    l = lcs_length(a_n, b_n)\n    return 2*l / (len(a_n)+len(b_n))\n\norig_span = \"ادعون ربكم تضرعا وخفية إنه لا يحب المعتدين ولا تفسدوا في الأرض بعد إصلاحها وادعوه خوفا وطمعا إن رحمة الله قريب من المحسنين\"\nayah55 = next(v for v in quran_data if v['surah_id']==7 and v['ayah_id']==55)['ayah_text']\nayah56 = next(v for v in quran_data if v['surah_id']==7 and v['ayah_id']==56)['ayah_text']\ncandidate = ayah55 + \" \" + ayah56\nsim = sim_ratio(orig_span, candidate)\nsim, normalize_ar(orig_span), normalize_ar(candidate)[:1000]",
