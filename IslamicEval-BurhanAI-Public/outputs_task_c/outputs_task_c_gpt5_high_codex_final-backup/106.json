      "id": "ci_689679105dec8195b37fe6a020e42c900c76117201fbe909",
      "code": "arabic_diacritics = re.compile(r'[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]')\ntatweel = '\\u0640'\n\ndef normalize_ar(s):\n    if s is None:\n        return ''\n    s = s.replace(tatweel, '')\n    s = arabic_diacritics.sub('', s)\n    # unify hamza forms\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\n    # remove punctuation\n    s = re.sub(r'[^\\w\\s]', ' ', s, flags=re.UNICODE)\n    # collapse spaces and lowercase\n    s = re.sub(r'\\s+', ' ', s).strip().lower()\n    return s\n\ndef search_quran_by_substring(query):\n    nq = normalize_ar(query)\n    results = []\n    for v in quran_data:\n        nt = normalize_ar(v['ayah_text'])\n        if nq in nt:\n            results.append(v)\n    return results\n\nquery1 = \"وَإِذْ أَخَذَ رَبُّكَ مِنْ بَنِي آدَمَ\"\nlen(search_quran_by_substring(query1))",
