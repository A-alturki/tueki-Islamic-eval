      "id": "ci_689679398c8881939a3c9db79fd7492a0a07dd2e31f67022",
      "code": "def token_f1(a,b):\n    atoks = a.split()\n    btoks = b.split()\n    aset = set(atoks)\n    bset = set(btoks)\n    inter = aset & bset\n    if not inter:\n        return 0.0\n    prec = sum(1 for t in atoks if t in bset)/len(atoks)\n    rec = sum(1 for t in btoks if t in aset)/len(btoks)\n    if prec+rec == 0:\n        return 0.0\n    f1 = 2*prec*rec/(prec+rec)\n    return f1, prec, rec, len(inter), len(aset), len(bset), inter\n\nfor idx in hits_lazul:\n    f1_stats = token_f1(norm_full, norm_texts[idx])\n    print(idx, f1_stats[:4], f1_stats[6])",
