      "id": "ci_689678fb762c819390af2b1928d890100a07dd2e31f67022",
      "code": "import regex as re\n\n# Arabic diacritics regex\narabic_diacritics = re.compile(r'[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]')\ntatweel = '\\u0640'\n\ndef normalize_ar(s):\n    if s is None:\n        return ''\n    s = s.replace(tatweel, '')\n    s = arabic_diacritics.sub('', s)\n    # unify hamza forms\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\n    # remove punctuation and non-letters but keep spaces\n    s = re.sub(r'[^\\p{Arabic}\\p{N}\\s]', ' ', s)\n    # collapse multiple spaces\n    s = re.sub(r'\\s+', ' ', s).strip().lower()\n    return s\n\ntarget_full = \"من مشى مع أخيه المسلم في حاجة حتى تتهيأ له، أثبت الله قدمه يوم تزول الأقدام\"\ntarget_snip = \"من مشى مع ...ول الأقدام\"\nnorm_full = normalize_ar(target_full)\nnorm_full",
