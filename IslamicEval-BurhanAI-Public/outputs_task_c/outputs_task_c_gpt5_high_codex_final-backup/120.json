    {
      "id": "ci_6896790320f48193a430b951272f23540a07dd2e31f67022",
      "code": "def get_text(h):\n    txt = ''\n    if h.get('hadithTxt'):\n        txt += h['hadithTxt']\n    if h.get('Matn') and h.get('Matn') != h.get('hadithTxt'):\n        if txt:\n            txt += ' || ' + h['Matn']\n        else:\n            txt = h['Matn']\n    return txt\n\n# Precompute normalized texts \nnorm_texts = []\nfor h in hadiths:\n    t = get_text(h)\n    norm_texts.append(normalize_ar(t))\n\n# search for tokens 'من مشى' etc\ndef find_contains(substr):\n    nsub = normalize_ar(substr)\n    res = []\n    for i, ntext in enumerate(norm_texts):\n        if nsub in ntext:\n            res.append(i)\n    return res\n\ncontains_mansha = find_contains(\"من مشى\")\nlen(contains_mansha)",
