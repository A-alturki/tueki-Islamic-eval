      "id": "ci_689678e1a1d88196bc2302d490a3aec8020339dfc61a7c1a",
      "code": "# Let's compute normalized longest common subsequence similarity between candidate and full span.\r\ndef lcs(a, b):\r\n    n, m = len(a), len(b)\r\n    dp = [0]*(m+1)\r\n    for i in range(1, n+1):\r\n        prev = 0\r\n        for j in range(1, m+1):\r\n            temp = dp[j]\r\n            if a[i-1] == b[j-1]:\r\n                dp[j] = prev + 1\r\n            else:\r\n                dp[j] = max(dp[j], dp[j-1])\r\n            prev = temp\r\n    return dp[m]\r\n\r\nfull_span = \"يا أيها الناس، إنما النساء شقائق الرجال\"\r\ncandidate = \"إنما النساء شقائق الرجال\"\r\nlcs_len = lcs(full_span, candidate)\r\nlen_full = len(full_span)\r\nlen_cand = len(candidate)\r\nlcs_len, len_full, len_cand, lcs_len / max(len_full, len_cand), lcs_len / len_full, lcs_len / len_cand\n",
