      "id": "ci_689678f527b48196b6053f504cc3933e020339dfc61a7c1a",
      "code": "# normalization function\r\nARABIC_DIACRITICS = re.compile('[\\u0610-\\u061A\\u064B-\\u065F\\u06D6-\\u06DC\\u06DF-\\u06E8\\u06EA-\\u06ED]')\r\nTATWEEL = '\\u0640'\r\nPUNCT = re.compile(r'[^\\w\\s\\u0600-\\u06FF]')  # remove non Arabic letters/numbers/underscore\r\ndef normalize_ar(s):\r\n    if s is None:\r\n        return None\r\n    s = s.replace(TATWEEL, '')\r\n    s = ARABIC_DIACRITICS.sub('', s)\r\n    # unify alef forms\r\n    s = re.sub('[\\u0622\\u0623\\u0625\\u0671]', 'ا', s)  # آأإٱ -> ا\r\n    s = s.replace('ى', 'ي')\r\n    s = s.replace('ة', 'ه')  # maybe unify ta marbuta\r\n    s = s.replace('ؤ', 'و').replace('ئ', 'ي')\r\n    # remove punctuation\r\n    s = PUNCT.sub(' ', s)\r\n    # collapse spaces\r\n    s = re.sub(r'\\s+', ' ', s).strip()\r\n    return s\r\n\r\nquery1 = \"شقائق الرجال\"\r\nquery2 = \"إنما النساء شقائق الرجال\"\r\nqueries = [query1, query2, \"انما النساء شقائق الرجال\"]\r\nnorm_queries = [normalize_ar(q) for q in queries]\r\nnorm_queries\n",
      "container_id": "cntr_689678d4c98881909250f5db297a64ae022bd531da772be5",
      "outputs": null,
