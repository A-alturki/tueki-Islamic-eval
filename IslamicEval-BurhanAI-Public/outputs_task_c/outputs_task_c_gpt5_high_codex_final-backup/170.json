    {
      "id": "ci_6896792e57b08197948807f1cd6136bb0ab9ed5719b28ca6",
      "code": "def lcs_length(a,b):\n    # simple DP\n    n,m=len(a),len(b)\n    dp=[[0]*(m+1) for _ in range(n+1)]\n    for i,ch in enumerate(a,1):\n        for j,ch2 in enumerate(b,1):\n            dp[i][j]=dp[i-1][j-1]+1 if ch==ch2 else max(dp[i-1][j], dp[i][j-1])\n    return dp[n][m]\ndef sim_ratio(a,b):\n    # normalized LCS by average length? design threshold accordingly\n    l=lcs_length(a,b)\n    return l/max(len(a),len(b))\ndef token_f1(a,b):\n    # simple whitespace tokenization of normalized strings\n    ta=a.split()\n    tb=b.split()\n    setA=set(ta); setB=set(tb)\n    inter=len(setA & setB)\n    if not setA or not setB: return 0.0\n    prec=inter/len(setA); rec=inter/len(setB)\n    if prec+rec==0: return 0.0\n    return 2*prec*rec/(prec+rec)\nsim_ratio(orig_norm,qaf_norm), token_f1(orig_norm,qaf_norm)",
