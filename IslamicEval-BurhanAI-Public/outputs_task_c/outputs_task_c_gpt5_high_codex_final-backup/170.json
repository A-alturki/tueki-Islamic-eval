    {
      "id": "ci_68967912c73081979c7258f526c330e30ab9ed5719b28ca6",
      "code": "import re\nAR_DIACRITICS = ''.join(chr(c) for c in range(0x0610, 0x061A+1)) + ''.join(chr(c) for c in range(0x064B, 0x065F+1)) + ''.join(chr(c) for c in range(0x0670, 0x0670+1)) + ''.join(chr(c) for c in range(0x06D6, 0x06DC+1)) + ''.join(chr(c) for c in range(0x06DF, 0x06E8+1)) + ''.join(chr(c) for c in range(0x06EA, 0x06ED+1))\n# Tatweel 0640, small maddah? We'll remove.\ndef normalize_ar(s):\n    if s is None: return ''\n    s = str(s)\n    # unify alef forms to ا, yaa to ي, taa marbuta to ة? Keep?\n    replacements = {\n        'أ':'ا','إ':'ا','آ':'ا','ى':'ي','ي':'ي','ئ':'ي','ؤ':'و','ة':'ه','ۀ':'ه','گ':'ك','ڤ':'ف','پ':'ب','ٰ':'', 'ؤ':'و',\n        'ﻻ':'لا','لا':'لا','ٱ':'ا','ٰ':'', 'ﺍ':'ا','ﺁ':'ا',\n    }\n    # Remove harakat and Quranic marks\n    s = re.sub('['+AR_DIACRITICS+'\\u0640\\u06F0-\\u06F9\\u0660-\\u0669\\u0670\\u06DD\\u06DE\\u06E0]', '', s)\n    for k,v in replacements.items():\n        s = s.replace(k, v)\n    # Remove punctuation\n    s = re.sub(r'[^\\u0600-\\u06FF\\s]', ' ', s)\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\ndef norm_collapse(s):\n    return normalize_ar(s)\n\nqnorm = [norm_collapse(v['ayah_text']) for v in quran_data]\ndef find_sub(s):\n    ns = norm_collapse(s)\n    hits=[]\n    for i,v in enumerate(quran_data):\n        if ns in qnorm[i]:\n            hits.append((i, v))\n    return hits\n\ntest_phrase = 'ونحن أقرب إليه منكم ولكن لا تبصرون'\nfind_sub(test_phrase)[:5], len(find_sub(test_phrase))",
      "container_id": "cntr_689678d5190c819092f5f66c03324e7a0fedc76a426839dd",
