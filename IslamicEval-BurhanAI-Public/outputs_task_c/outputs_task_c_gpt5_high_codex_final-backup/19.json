      "id": "ci_689678faa7f481909c1ba0d7fb1c472e045e926c306a60be",
      "code": "import re, unicodedata\n\nHARAKAT = ''.join(chr(i) for i in range(0x064B, 0x065F+1)) + '\\u0670'  # tashkeel + small alef\nTATWEEL = '\\u0640'\nPUNCTS = ''.join([c for c in map(chr, range(0x0600, 0x06FF)) if unicodedata.category(c).startswith('P')])\nARABIC_PUNCT = ''.join(ch for ch in \"؟،؛٪٬٭﴾﴿ـ\" )\n\ndef normalize_ar(s):\n    if s is None:\n        return ''\n    # remove tashkeel and small alef\n    s = re.sub(f'[{HARAKAT}]', '', s)\n    # remove tatweel\n    s = s.replace(TATWEEL, '')\n    # normalize hamza on alif\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا')\n    # normalize waw/ya hamza\n    s = s.replace('ؤ','و').replace('ئ','ي')\n    # normalize maqsurah to ya\n    s = s.replace('ى','ي')\n    # normalize ta marbuta to ha? better to map to same char?\n    # I will map 'ة' to 'ه' to avoid mismatches based on writing\n    s = s.replace('ة','ه')\n    # remove punctuation\n    s = re.sub(r'[^\\u0600-\\u06FF\\s]+', ' ', s)\n    s = s.replace('،',' ').replace('؛',' ').replace('؟',' ').replace('ـ',' ')\n    # collapse whitespace\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\ndef find_quran_candidates(query, surah=None):\n    nq = normalize_ar(query)\n    results = []\n    for rec in quran:\n        ayah = rec['ayah_text']\n        nayah = normalize_ar(ayah)\n        if nq and nq in nayah:\n            results.append(rec)\n    return results\n\nquery = \"وَقَالَ مُوسَىٰ إِنِّي عُذْتُ بِرَبِّي وَرَبِّكُم مِّن كُلِّ مُتَكَبِّرٍ لَّا يُؤْمِنُ بِيَوْمِ الْحِسَابِ\"\ncands = find_quran_candidates(query)\nlen(cands), cands[:3]",
