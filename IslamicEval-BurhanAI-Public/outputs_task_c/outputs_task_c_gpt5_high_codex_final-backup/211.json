      "id": "ci_6896790dae40819689552262c983165608c13e14d80d67ff",
      "code": "# Helper functions for Arabic normalization and diacritics removal\narabic_diacritics = re.compile(r\"[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06DC\\u06DF-\\u06E8\\u06EA-\\u06ED]\")\n\ndef strip_diacritics(s):\n    return arabic_diacritics.sub(\"\", s)\n\ndef normalize_ar(s):\n    s = s.replace(\"\\u0640\", \"\")  # tatweel\n    s = strip_diacritics(s)\n    # unify alef forms\n    s = re.sub(\"[\\u0622\\u0623\\u0625\\u0671]\", \"\\u0627\", s)\n    # unify ya and alif maqsura\n    s = s.replace(\"\\u0649\", \"\\u064a\")\n    # unicode normalize\n    s = unicodedata.normalize(\"NFKC\", s)\n    # remove punctuation\n    s = re.sub(r\"[^\\w\\s\\u0600-\\u06FF]\", \" \", s)\n    # collapse whitespace\n    s = re.sub(r\"\\s+\", \" \", s).strip()\n    return s\n\ndef search_entries(term, fields=(\"hadithTxt\",\"Matn\"), max_hits=50):\n    norm_term = normalize_ar(term)\n    hits = []\n    for i, rec in enumerate(hadith_data):\n        for field in fields:\n            txt = rec.get(field) or \"\"\n            if not txt: \n                continue\n            n = normalize_ar(txt)\n            if norm_term in n:\n                hits.append((i, field, txt))\n                break\n        if len(hits) >= max_hits:\n            break\n    return hits\n\nterm = \"البنيان يشد بعضه بعضا\"\nhits = search_entries(term)\nlen(hits)",
