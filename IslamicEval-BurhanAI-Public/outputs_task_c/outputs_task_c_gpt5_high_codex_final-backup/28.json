      "id": "ci_689678fa9d5c819586262dafc2619a2e0b128eecdb40928f",
      "code": "def normalize_arabic(s):\n    # Strip diacritics, tatweel, punctuation; unify hamza forms to basic; lowercase, collapse spaces.\n    if s is None:\n        return \"\"\n    # remove tashkeel (harakat)\n    arabic_diacritics = re.compile(r'[\\u0610-\\u061A\\u064B-\\u065F\\u06D6-\\u06ED]')\n    s = arabic_diacritics.sub('', s)\n    # remove tatweel\n    s = s.replace('ـ','')\n    # unify hamza: convert all alef forms to bare alif\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ى','ي').replace('ة','ه').replace('ؤ','و').replace('ئ','ي')\n    # remove punctuation and quotes\n    s = re.sub(r'[^\\w\\s]', ' ', s, flags=re.UNICODE)\n    # lowercase (not relevant)\n    s = s.lower()\n    # collapse spaces\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\nspan_full = \"وَلَقَدْ هَدَيْنَا لُوطًا\"\nnorm_span = normalize_arabic(span_full)\nnorm_span",
      "container_id": "cntr_689678d5294081909cdda481f24d6ee9008249feeafe2e89",
