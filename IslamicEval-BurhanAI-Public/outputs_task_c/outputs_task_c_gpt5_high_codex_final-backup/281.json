      "code": "def normalize(s):\n    # remove tashkeel and tatweel, unify hamza forms, normalize spaces\n    s = re.sub('[\\u064B-\\u0652\\u0670\\u0653-\\u065F]', '', s) # remove harakat, superscript alif\n    s = s.replace('ـ', '')\n    # unify alef and hamza forms\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\n    s = s.replace('ٱ','ا')\n    s = re.sub(r'\\s+',' ', s).strip()\n    return s\n\ntarget_full = \"وَإِذْ أَخَذَ رَبُّكَ مِنْ بَنِي آدَمَ مِنْهُمْ أَزْوَاجَهُمْ وَأَذَقَهُمْ مِنْ رَبِّهِمْ الْحَمْلَ وَالْعَذَابَ الْأَلِيمَ لِيَجْعَلَ فِي قُلُوبِهِمُ الْحُبَّ\"\ntarget_snip = \"وَإِذْ أَخ...ُ الْحُبَّ\"\nnorm_full = normalize(target_full)\nnorm_full",
