    {
      "id": "ci_689678ee0d00819793a1761efeb7644b08a5d5deae02a7a6",
      "code": "def strip_tashkeel(s):\n    # Remove diacritics (Arabic)\n    # Remove tatweel (U+0640)\n    return ''.join(ch for ch in s if ch != '\\u0640' and not unicodedata.combining(ch))\n\ndef normalize_arabic(s):\n    s = s.strip()\n    s = strip_tashkeel(s)\n    # unify hamza forms\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ٱ','ا')\n    s = s.replace('ى','ي').replace('ئ','ي').replace('ؤ','و')\n    s = s.replace('ة','ه')\n    # remove punctuation and non-letters/digits/spaces\n    s = re.sub(r'[^\\w\\s]', ' ', s, flags=re.UNICODE)\n    # lowercase just in case (though Arabic unaffected)\n    s = s.lower()\n    # collapse whitespace\n    s = re.sub(r'\\s+', ' ', s)\n    return s\n\ndef search_quran(substring):\n    norm_sub = normalize_arabic(substring)\n    results = []\n    for item in quran_data:\n        text = item['ayah_text']\n        norm_text = normalize_arabic(text)\n        if norm_sub in norm_text:\n            results.append(item)\n    return results\n\nquery = \"تزكوا أنفسكم\"\nresults = search_quran(query)\nlen(results), results[:3]",
      "container_id": "cntr_689678d4d6f08190939f2a8a80bf7a660a281693899a99dc",
      "outputs": null,
      "status": "completed",
      "type": "code_interpreter_call"
    },
