    {
      "id": "ci_689678f6a0fc81978d6ba56297837a2a08a5d5deae02a7a6",
      "code": "orig = \"وَلَا تُزَكُّوا أَنفُسَكُمْ هُوَ أَعْلَمُ بِمَا فِي نُفُوسِكُمْ\"\ncand = results[0]['ayah_text']  # full ayah; but we should maybe candidate phrase inside?\ncand_phrase = \"فَلَا تُزَكُّوا أَنْفُسَكُمْ ۖ هُوَ أَعْلَمُ بِمَنِ اتَّقَىٰ\"\ndef lcs_length(a,b):\n    # compute LCS length for sequences of characters\n    # dynamic programming\n    la, lb = len(a), len(b)\n    dp = [0]*(lb+1)\n    for i in range(1, la+1):\n        prev = 0\n        ai = a[i-1]\n        for j in range(1, lb+1):\n            tmp = dp[j]\n            if ai == b[j-1]:\n                dp[j] = prev + 1\n            else:\n                dp[j] = max(dp[j], dp[j-1])\n            prev = tmp\n    return dp[lb]\ndef sim_ratio(a,b):\n    aN = normalize_arabic(a)\n    bN = normalize_arabic(b)\n    L = lcs_length(aN, bN)\n    return L / max(len(aN), len(bN))\nprint(normalize_arabic(orig), len(normalize_arabic(orig)))\nprint(normalize_arabic(cand_phrase), len(normalize_arabic(cand_phrase)))\nprint(sim_ratio(orig, cand_phrase))",
