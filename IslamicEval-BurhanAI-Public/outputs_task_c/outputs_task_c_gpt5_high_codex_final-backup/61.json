      "id": "ci_6896790170c081908ce18288048de1fe0c57e89ad894504e",
      "code": "# Arabic normalization\nAR_DIACRITICS = re.compile(r\"[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]\")\nTATWEEL = \"\\u0640\"\n\ndef normalize_ar(text):\n    # Remove diacritics\n    text = AR_DIACRITICS.sub(\"\", text)\n    # Remove tatweel\n    text = text.replace(TATWEEL, \"\")\n    # Standardize alif/hamza\n    text = text.replace(\"أ\", \"ا\").replace(\"إ\", \"ا\").replace(\"آ\", \"ا\")\n    text = text.replace(\"ى\", \"ي\").replace(\"ئ\", \"ي\").replace(\"ؤ\", \"و\")\n    # standard taa marbuta?\n    # text = text.replace(\"ة\", \"ه\")  # maybe not\n    # Remove punctuation\n    text = re.sub(r\"[^\\w\\s\\u0621-\\u063A\\u0641-\\u064A]\", \" \", text)\n    # Collapse spaces\n    text = re.sub(r\"\\s+\", \" \", text).strip()\n    return text\n\nnq = [dict(rec, ayah_text_norm=normalize_ar(rec['ayah_text'])) for rec in qdb]\nnh = []\nfor rec in hdb:\n    # both possible fields, choose Matn or hadithTxt; we'll create 'text' normalized from either; preserve both\n    text = rec.get('Matn') or rec.get('hadithTxt') or \"\"\n    nh.append({**rec, 'text': text, 'text_norm': normalize_ar(text)})\n    \n# Test normalization on Ayah\nprint(nq[0]['ayah_text'][:50])\nprint(nq[0]['ayah_text_norm'][:50])",
