      "id": "ci_689678fde3b08190895e2c83b7c1744e023ce7b8d61b3d73",
      "code": "import re, unicodedata\n\n# Arabic diacritics set\narabic_diacritics = re.compile(r\"[\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]\")\n\ndef normalize_arabic(s):\n    if s is None:\n        return \"\"\n    s = str(s)\n    # Remove tatweel\n    s = s.replace(\"ـ\", \"\")\n    # Remove diacritics\n    s = arabic_diacritics.sub(\"\", s)\n    # Normalize different alifs/hamzas/ya/ta marbuta\n    s = s.replace(\"إ\", \"ا\").replace(\"أ\", \"ا\").replace(\"آ\", \"ا\").replace(\"ٱ\", \"ا\")\n    s = s.replace(\"ى\", \"ي\").replace(\"ؤ\", \"و\").replace(\"ئ\", \"ي\").replace(\"ة\", \"ه\")\n    # Remove punctuation and non-letters digits except spaces\n    s = re.sub(r\"[^\\u0600-\\u06FF\\s]\", \" \", s)\n    # Collapse spaces\n    s = re.sub(r\"\\s+\", \" \", s).strip()\n    return s\n\ndef token_set(s):\n    return set(normalize_arabic(s).split())\n\ndef lcs_length(a, b):\n    # normalized strings without spaces maybe\n    A = normalize_arabic(a).replace(\" \", \"\")\n    B = normalize_arabic(b).replace(\" \", \"\")\n    # dynamic programming\n    n, m = len(A), len(B)\n    dp = [0]*(m+1)\n    for i in range(1, n+1):\n        prev = 0\n        for j in range(1, m+1):\n            tmp = dp[j]\n            if A[i-1] == B[j-1]:\n                dp[j] = prev + 1\n            else:\n                dp[j] = max(dp[j], dp[j-1])\n            prev = tmp\n    return dp[m], A, B\n\ndef sim_ratio(a, b):\n    lcs, A, B = lcs_length(a, b)\n    if len(A) + len(B) == 0:\n        return 0.0\n    return 2*lcs/(len(A)+len(B))\n\nprint(normalize_arabic(\"وَعَدَدَ ل\"))\nprint(normalize_arabic(\"وَعَدَ ٱللَّهُ\"))\nprint(normalize_arabic(\"وَعَدَكُمُ ٱللَّهُ\"))",
      "container_id": "cntr_689678d4b4988190a325e37f182c35530b10b59dd240dbff",
