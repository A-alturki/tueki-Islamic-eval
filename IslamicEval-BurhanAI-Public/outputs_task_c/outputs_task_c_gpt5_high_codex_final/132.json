      "id": "ci_689678feb89481968406523209e05029026bccecc83eeebf",
      "code": "import re, unicodedata, math, difflib, itertools\nAR_DIACRITICS = ''.join(chr(c) for c in range(0x064B, 0x065F+1)) + '\\u0670' + '\\u0640'\nDIAC_RE = re.compile('[%s]' % re.escape(AR_DIACRITICS))\ndef normalize(s):\n    if s is None:\n        return ''\n    s = re.sub(r'[^\\u0600-\\u06FF\\s]+', ' ', s)  # remove non-Arabic letters/punct\n    s = DIAC_RE.sub('', s)\n    s = s.replace('ٱ', 'ا')\n    s = s.replace('أ', 'ا').replace('إ', 'ا').replace('آ', 'ا')\n    s = s.replace('ؤ', 'و').replace('ئ', 'ي').replace('ة', 'ه')\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\ndef token_set_f1(a, b):\n    # simple token f1 by bag-of-words\n    A = normalize(a).split()\n    B = normalize(b).split()\n    if not A and not B:\n        return 1.0\n    sa, sb = collections.Counter(A), collections.Counter(B)\n    # compute overlap counts\n    overlap = 0\n    for w in set(sa.keys()) & set(sb.keys()):\n        overlap += min(sa[w], sb[w])\n    prec = overlap / (sum(sa.values()) or 1)\n    rec = overlap / (sum(sb.values()) or 1)\n    if prec+rec==0:\n        return 0.0\n    return 2*prec*rec/(prec+rec)\n\ndef lcs_ratio(a, b):\n    a_n = normalize(a)\n    b_n = normalize(b)\n    seq = difflib.SequenceMatcher(None, a_n, b_n)\n    return seq.ratio()\n\ndef combined_score(a,b):\n    return 0.5*token_set_f1(a,b) + 0.5*lcs_ratio(a,b)\n\norig = \"وَمِنَ الأُولِيَاءِ الَّذِينَ تَرَكُوا دِيَاتَهُمْ وَطاعَنُوا لَا مُبَدِّلَ لِها وَلَهُمُ الْوَرِثَةُ\"\norig",
