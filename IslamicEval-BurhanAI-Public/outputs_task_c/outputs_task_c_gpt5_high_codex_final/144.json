      "id": "ci_68967eae1b248196977dd067bdb801360f0a21e462d78af6",
      "code": "import re\r\ndef strip_tashkeel(s):\r\n    # Remove Arabic diacritics\r\n    arabic_diacritics = re.compile(r'[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]')\r\n    s = arabic_diacritics.sub('', s)\r\n    # Arabic tatweel\r\n    s = s.replace('\\u0640','')\r\n    return s\r\n\r\ndef normalize_hamza(s):\r\n    # Replace hamza variations with bare alif where appropriate\r\n    # We'll map أإآٱ to ا\r\n    return (s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ٱ','ا')\r\n              .replace('ؤ','و').replace('ئ','ي').replace('ة','ه'))\r\n\r\ndef normalize_text(s):\r\n    s = strip_tashkeel(s)\r\n    s = normalize_hamza(s)\r\n    # remove punctuation and extra spaces\r\n    s = re.sub(r'[^\\u0600-\\u06FF0-9 ]',' ', s)\r\n    s = re.sub(r'\\s+',' ', s).strip().lower()\r\n    return s\r\n\r\nns_original = normalize_text(original_span)\r\nns_candidate = normalize_text(candidate)\r\n\r\nns_original, ns_candidate, len(ns_original), len(ns_candidate)",
