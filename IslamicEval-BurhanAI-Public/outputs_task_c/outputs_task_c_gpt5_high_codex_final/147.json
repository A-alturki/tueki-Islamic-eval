      "code": "import re, unicodedata\n\n# Arabic diacritics pattern\narabic_diacritics = re.compile(r'[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06DC\\u06DF-\\u06E8\\u06EA-\\u06ED]')\ntatweel = '\\u0640'\n\ndef normalize_ar(text):\n    text = text.replace(tatweel, '')\n    text = arabic_diacritics.sub('', text)\n    # unify different alef forms to bare alif\n    text = re.sub('[\\u0622\\u0623\\u0625\\u0671]', '\\u0627', text)  # آ,أ,إ,ٱ -> ا\n    # yaa alef maqsura: normalize to ي?\n    text = text.replace('\\u0649', '\\u064A')\n    # taa marbuta to ه?\n    # We'll keep ة as ه or as ت? For search we can transform to ه or to ة unify?\n    text = text.replace('\\u0629', '\\u0647')  # ة -> ه\n    # heh+superscript alef? (dagger alif U+0670 removed by diacritics)\n    text = text.replace('ـ', '')\n    # Remove punctuation\n    text = re.sub(r'[^\\u0600-\\u06FF\\s]', ' ', text)\n    # collapse spaces\n    text = re.sub(r'\\s+', ' ', text).strip()\n    return text\n\nsnippet=\"الرجال قوامون على النساء بما فضل الله بعضهم على بعض وبما أنفقوا من أموالهم\"\nnorm_snippet=normalize_ar(snippet)\nnorm_snippet[:200]",
