      "code": "def normalize_arabic(s):\n    if s is None: \n        return \"\"\n    # normalize hamza forms to bare alif?\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ة','ه').replace('ى','ي')\n    # remove tashkeel\n    tashkeel = ''.join(chr(c) for c in range(0x0617, 0x061A+1)) + ''.join(chr(c) for c in range(0x064B,0x065F+1)) + ''.join(chr(c) for c in range(0x0670,0x0670+1)) + ''.join(chr(c) for c in range(0x06D6,0x06ED+1))\n    s = re.sub('['+re.escape(tashkeel)+']','', s)\n    # remove tatweel\n    s = s.replace('ـ','')\n    # remove punctuation\n    s = re.sub(r'[^\\u0621-\\u063A\\u0641-\\u0669\\s]', ' ', s)\n    # collapse spaces\n    s = re.sub(r'\\s+', ' ', s).strip().lower()\n    return s\n\ndef sim_ratio(a,b):\n    # token F1 or normalized LCS\n    na, nb = normalize_arabic(a), normalize_arabic(b)\n    sm=difflib.SequenceMatcher(a=na,b=nb)\n    return sm.ratio()\n\nsnippet = \"لا يُقبل من أحد إلا من آمن\"\nnormalize_arabic(snippet), snippet",
