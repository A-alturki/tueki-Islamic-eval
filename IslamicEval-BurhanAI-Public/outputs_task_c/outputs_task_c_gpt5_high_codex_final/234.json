    {
      "id": "ci_6896794f1e288196a07511e7a29c269004de792e1112a69c",
      "code": "def lcs_length(a, b):\r\n    # LCS length of sequences a and b (characters)\r\n    n, m = len(a), len(b)\r\n    dp = [0]*(m+1)\r\n    for i in range(1, n+1):\r\n        ndp = [0]*(m+1)\r\n        ai = a[i-1]\r\n        for j in range(1, m+1):\r\n            if ai == b[j-1]:\r\n                ndp[j] = dp[j-1] + 1\r\n            else:\r\n                ndp[j] = dp[j] if dp[j] >= ndp[j-1] else ndp[j-1]\r\n        dp = ndp\r\n    return dp[m]\r\n\r\ndef lcs_ratio(a, b):\r\n    # LCS length / max(len(a), len(b))\r\n    if not a or not b:\r\n        return 0.0\r\n    l = lcs_length(a, b)\r\n    return l / max(len(a), len(b))\r\n\r\nfull_span = \"وَكَذَلِكَ نُفَصِّلُ الْآيَاتِ لِقَوْمٍ يُؤْمِنُونَ (60) وَيَزِدُ الظَّالِمِينَ ظُلْمَهُمْ (61) وَيَزِدُ الْكَافِرِينَ كُفْرَهُمْ (62) وَمَا أَرْس\"\r\nn_full = norm(full_span)\r\nn_full\n",
