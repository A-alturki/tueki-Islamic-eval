      "code": "def hadith_norm_text(h):\r\n    text = h.get('hadithTxt') or h.get('Matn') or ''\r\n    return norm(text)\r\n\r\nhnorms = [hadith_norm_text(h) for h in hadith]\r\nhtxts = [h.get('hadithTxt') or h.get('Matn') or '' for h in hadith]\r\n\r\ndef hadith_search(phrase):\r\n    nq = norm(phrase)\r\n    hits = []\r\n    for i, t in enumerate(htxts):\r\n        if nq in hnorms[i]:\r\n            hits.append(i)\r\n    return hits\r\n\r\nlen(hadith_search(\"وكذلك نفصل\")), len(hadith_search(\"وما ارسل\"))\n",
