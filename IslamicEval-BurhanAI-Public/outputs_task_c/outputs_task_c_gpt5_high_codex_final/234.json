      "id": "ci_689678f716a48196be4cd476d617b9ed04de792e1112a69c",
      "code": "import re, unicodedata\r\n\r\ndef remove_diacritics(s):\r\n    # Remove Arabic diacritics\r\n    arabic_diacritics = re.compile(r'[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06DC\\u06DF-\\u06E8\\u06EA-\\u06ED]')\r\n    return arabic_diacritics.sub('', s)\r\n\r\ndef normalize_ar(s):\r\n    s = s.replace('ـ','')  # tatweel\r\n    s = remove_diacritics(s)\r\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا')\r\n    s = s.replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\r\n    s = re.sub(r'[^\\u0600-\\u06FF0-9 ]+', ' ', s)  # remove punctuation\r\n    s = re.sub(r'\\s+',' ', s).strip()\r\n    return s\r\n\r\ndef norm(s):\r\n    return normalize_ar(s).lower()\r\n\r\n# Build search index of quran\r\nq_norm_texts = [norm(a['ayah_text']) for a in quran]\r\nq_texts = [a['ayah_text'] for a in quran]\r\n\r\ndef search_substring(query, within):\r\n    nq = norm(query)\r\n    res = []\r\n    for i,t in enumerate(q_texts):\r\n        if nq in q_norm_texts[i]:\r\n            res.append(i)\r\n    return res\r\n\r\ndef find_with_phrase(phrase):\r\n    idxs = search_substring(phrase, quran)\r\n    return [(i, quran[i]['surah_id'], quran[i]['ayah_id'], quran[i]['ayah_text']) for i in idxs]\r\n\r\nphrase = \"وَكَذَلِكَ نُفَصِّلُ الْآيَاتِ لِقَوْمٍ يُؤْمِنُونَ\"\r\nfind_with_phrase(phrase)[:10], len(find_with_phrase(phrase))\n",
