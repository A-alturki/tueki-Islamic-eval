      "code": "def get_ayah(surah, ayah):\r\n    for a in quran:\r\n        if a['surah_id']==surah and a['ayah_id']==ayah:\r\n            return a['ayah_text']\r\n    return None\r\n\r\ncandidates = {\r\n    \"6:55\": get_ayah(6,55),\r\n    \"7:174\": get_ayah(7,174),\r\n    \"17:82\": get_ayah(17,82),\r\n    \"12:109\": get_ayah(12,109),\r\n    \"16:43\": get_ayah(16,43),\r\n    \"21:7\": get_ayah(21,7)\r\n}\r\ncandidates\n",
