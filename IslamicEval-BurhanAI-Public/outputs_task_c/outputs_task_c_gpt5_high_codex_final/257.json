      "id": "ci_689678f31ecc8195a350cf9e8635cb2601e59f973ca0e8dd",
      "code": "import re, unicodedata, difflib\narabic_diacritics = re.compile(r'[\\u0610-\\u061a\\u064b-\\u065f\\u06d6-\\u06ed]')\ntatweel_re = re.compile(r'[\\u0640]')\npunct_re = re.compile(r'[^\\w\\s\\u0600-\\u06FF]')  # keep Arabic letters/digits/underscore\nspaces_re = re.compile(r'\\s+')\ndef normalize(s):\n    if s is None:\n        return ''\n    s = str(s)\n    s = tatweel_re.sub('', s)\n    s = arabic_diacritics.sub('', s)\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\n    s = punct_re.sub(' ', s)\n    s = spaces_re.sub(' ', s).strip()\n    return s\n\ndef lcs_similarity(a,b):\n    # Use SequenceMatcher ratio or compute token F1?\n    return difflib.SequenceMatcher(None, a, b).ratio()\n\ndef token_f1(a,b):\n    a_tokens = normalize(a).split()\n    b_tokens = normalize(b).split()\n    if not a_tokens and not b_tokens:\n        return 1.0\n    if not a_tokens or not b_tokens:\n        return 0.0\n    a_set = set(a_tokens)\n    b_set = set(b_tokens)\n    inter = len(a_set & b_set)\n    if inter == 0: \n        return 0.0\n    precision = inter / len(a_set)\n    recall = inter / len(b_set)\n    if precision + recall == 0:\n        return 0.0\n    return 2*precision*recall/(precision+recall)\n",
      "container_id": "cntr_689678d4a1f08190a6c503c42b3555160ce615daa5c98304",
      "outputs": null,
      "status": "completed",
