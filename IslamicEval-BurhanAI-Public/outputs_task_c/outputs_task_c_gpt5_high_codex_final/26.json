      "id": "ci_68967908d8bc8194b4b48b0f85a68f3907b344e6c9c9bde2",
      "code": "def norm_lcs_ratio(a,b):\n    # normalized to 0..1 by dividing by max(len(a), len(b))\n    # LCS algorithm dynamic; but difflib.SequenceMatcher ratio may suffice\n    return difflib.SequenceMatcher(None, a, b).ratio()\n\ndef token_f1(a,b):\n    ta = a.split()\n    tb = b.split()\n    set_a = set(ta); set_b = set(tb)\n    inter = len(set_a & set_b)\n    if len(set_a)==0 or len(set_b)==0:\n        return 0.0\n    prec = inter/len(set_a)\n    rec = inter/len(set_b)\n    if prec+rec==0:\n        return 0.0\n    return 2*prec*rec/(prec+rec)\n\ndef norm(s): return normalize_ar(s)\n\ncandidates = matches\nscores=[]\nfor mid,bid,text in candidates:\n    s=norm(text)\n    ratio=norm_lcs_ratio(norm_orig, s)\n    tf = token_f1(norm_orig, s)\n    scores.append((ratio, tf, mid, bid, text, s))\nsorted(scores, reverse=True)[:10]",
