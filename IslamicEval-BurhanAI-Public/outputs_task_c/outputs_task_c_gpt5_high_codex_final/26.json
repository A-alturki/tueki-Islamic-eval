      "id": "ci_689678f6946481948216db6bfc7b6f7a07b344e6c9c9bde2",
      "code": "def strip_diacritics(s):\n    # remove Arabic diacritics\n    # Keep Arabic letters and spaces\n    # Remove tashkeel\n    arabic_diacritics = re.compile(r'[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]')\n    s = arabic_diacritics.sub('', s)\n    return s\n\ndef normalize_ar(s):\n    if s is None:\n        return ''\n    s = str(s)\n    s = s.replace('\\u0640','')  # tatweel\n    s = strip_diacritics(s)\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ٱ','ا')\n    s = s.replace('ة','ه')\n    s = s.replace('ى','ي')\n    # remove punctuation\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]+',' ', s)\n    s = re.sub(r'\\s+',' ', s).strip().lower()\n    return s\n\norig_full = \"لا يؤمن أحدكم حتى أكون أحب إليه من وَلَدِهِ وَالدُنْيَا وَالناس جميعاً\"\nnorm_orig = normalize_ar(orig_full)\nnorm_orig",
      "container_id": "cntr_689678d4a1e0819094a016d6ba97624a0efd836d21496308",
      "outputs": null,
