    {
      "id": "ci_689678ff52bc81948bf589158456cfd207b344e6c9c9bde2",
      "code": "# Show these matches\nfor mid, bid, text in matches[:7]:\n    print(mid, bid)\n    snip = text\n    if len(snip)>400:\n        snip = snip[:400]\n    print(snip)\n    print('----')",
