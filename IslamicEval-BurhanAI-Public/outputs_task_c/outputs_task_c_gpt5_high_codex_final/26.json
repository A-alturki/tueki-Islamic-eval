      "type": "code_interpreter_call"
    },
    {
      "id": "ci_689678fbfb648194b9009d67f774751007b344e6c9c9bde2",
      "code": "# Search hadiths that contain \"لا يؤمن احدكم\" in normalized text\nmatches = []\nfor h in hadith_data:\n    text = h.get('Matn') or h.get('hadithTxt') or ''\n    norm = normalize_ar(text)\n    if 'لا يؤمن احدكم' in norm and 'احب' in norm:\n        matches.append((h['hadithID'], h['BookID'], text))\nlen(matches)",
      "container_id": "cntr_689678d4a1e0819094a016d6ba97624a0efd836d21496308",
      "outputs": null,
