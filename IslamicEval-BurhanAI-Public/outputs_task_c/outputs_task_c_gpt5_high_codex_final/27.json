      "code": "import re, unicodedata, math\nAR_DIACRITICS = ''.join([chr(c) for c in range(0x0610, 0x061A+1)]) + ''.join([chr(c) for c in range(0x064B, 0x065F+1)]) + ''.join([chr(c) for c in range(0x06D6, 0x06DC+1)]) + ''.join([chr(c) for c in range(0x06DF, 0x06E8+1)]) + ''.join([chr(c) for c in range(0x06EA, 0x06ED+1)])\nTATWEEL = '\\u0640'\nPUNCTUATION = r\"\"\"!()-[]{};:'\"\\,<>./?@#$%^&*_~ـ،؛؟…«»“”'`.,:+ـ\"\"\"\ndef normalize_ar(s):\n    if s is None:\n        return ''\n    # unify Arabic letters: alef forms etc.\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ٱ','ا')\n    s = s.replace('ى','ي').replace('ئ','ي').replace('ؤ','و')\n    s = s.replace('ة','ه')  # maybe unify? But might be too aggressive. Keep? We'll keep it for search normalization.\n    s = s.replace('ٰ','') # dagger alef\n    # remove diacritics\n    s = ''.join(ch for ch in s if ch not in AR_DIACRITICS and ch != TATWEEL)\n    # remove punctuation\n    s = ''.join(ch for ch in s if ch not in PUNCTUATION)\n    # collapse spaces\n    s = re.sub(r'\\s+',' ', s)\n    s = s.strip().lower()\n    return s\n\ndef lcs_length(a,b):\n    # compute LCS length on tokens? We'll do character-level for normalized strings.\n    n,m=len(a),len(b)\n    # limit memory? We'll do dynamic programming of O(min(n,m))?\n    # But we can use SequenceMatcher ratio\n    sm = difflib.SequenceMatcher(a=a,b=b)\n    return sum(triple.size for triple in sm.get_matching_blocks())\n\ndef sim_ratio(a,b):\n    a_n = normalize_ar(a)\n    b_n = normalize_ar(b)\n    if not a_n or not b_n: \n        return 0.0\n    lcs = lcs_length(a_n,b_n)\n    # Use 2*lcs/(len(a)+len(b)) akin to Dice-like\n    return 2*lcs/(len(a_n)+len(b_n))\n\ndef token_f1(a,b):\n    # token set overlap F1\n    a_n = normalize_ar(a)\n    b_n = normalize_ar(b)\n    a_tokens=set(a_n.split())\n    b_tokens=set(b_n.split())\n    if not a_tokens or not b_tokens:\n        return 0.0\n    common = len(a_tokens & b_tokens)\n    prec = common/len(a_tokens)\n    rec = common/len(b_tokens)\n    if prec+rec==0:\n        return 0.0\n    return 2*prec*rec/(prec+rec)\n\nspan_full = \"إِنَّ اللَهَ يَبْتَلِي الْمُؤْمِنينَ بِالذَنبِ وَاللَهُ يَبْتَلِي الْمُنافِقينَ بِالرِزقِ\"\nspan_snippet = \"إِنَّ اللَ... بِالرِزقِ\"\nprint(\"norm full:\", normalize_ar(span_full))\nprint(\"norm snippet:\", normalize_ar(span_snippet))",
