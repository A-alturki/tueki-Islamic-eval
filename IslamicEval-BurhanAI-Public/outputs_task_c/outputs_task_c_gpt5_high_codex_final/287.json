      "code": "import re, unicodedata\r\n\r\ndef strip_diacritics(s):\r\n    # Remove Arabic diacritics\r\n    arabic_diacritics = re.compile(r'[\\u0610-\\u061A\\u064B-\\u065F\\u06D6-\\u06ED]')\r\n    s = arabic_diacritics.sub('', s)\r\n    # also remove tatweel\r\n    s = s.replace('ـ','')\r\n    return s\r\n\r\ndef normalize_arabic(s):\r\n    if s is None:\r\n        return None\r\n    s = str(s)\r\n    s = strip_diacritics(s)\r\n    # unify hamza forms\r\n    s = re.sub('[أإآٱا]', 'ا', s)\r\n    s = re.sub('[ى]', 'ي', s)  # optional, unify alif maqsura to ya\r\n    s = re.sub('[ؤئ]', 'ء', s)\r\n    s = re.sub('[ة]', 'ه', s)  # unify ta marbuta to ha for search\r\n    # remove punctuation\r\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]', ' ', s)\r\n    s = re.sub(r'[_]', ' ', s)\r\n    # lowercase doesn't apply; normalize spaces\r\n    s = re.sub(r'\\s+', ' ', s).strip()\r\n    return s\r\n\r\ndef sim_ratio(a, b):\r\n    if a is None or b is None:\r\n        return 0.0\r\n    a_n = normalize_arabic(a)\r\n    b_n = normalize_arabic(b)\r\n    return SequenceMatcher(None, a_n, b_n).ratio()\r\n\r\noriginal_span = \"لما كان يوم العقبة لما أجمع الله عز وجل على نبوته، وأراد أن يبعثه، نزل جبريل عليه السلام في صورة رجل، ففزع الناس، فجئت حتى قعدت على فخذ رسول الله صلى الله عليه وسلم، فقلت: من صاحب الرجل الذي أقبل؟ فقال: هذا جبريل، فلم أومن به حتى رأيته في صورة بعوضة سوداء على شجرة\"\r\n\r\nnorm_span = normalize_arabic(original_span)\r\nnorm_span[:200], len(norm_span)",
