      "code": "def token_f1(a, b):\r\n    sa = set(tokenize2(a)); sb = set(tokenize2(b))\r\n    inter = len(sa & sb)\r\n    if not sa or not sb or inter==0: \r\n        return 0.0\r\n    prec = inter/len(sb)\r\n    rec = inter/len(sa)\r\n    f1 = 2*prec*rec/(prec+rec)\r\n    return f1\r\n\r\n# Compute best F1 and similarity ratio for the span across hadith dataset (might be slow but we can sample top)\r\nbest = (0, None, None)\r\nfor i, h in enumerate(hadith):\r\n    text = h.get('hadithTxt') or h.get('Matn') or ''\r\n    f1 = token_f1(original_span, text)\r\n    if f1 > best[0]:\r\n        best = (f1, i, h['title'])\r\nbest",
