      "code": "def token_set(s):\r\n    return set(tokenize2(s))\r\n\r\nspan_set = token_set(original_span)\r\n\r\ndef token_recall(h_text):\r\n    h_set = token_set(h_text)\r\n    inter = span_set & h_set\r\n    rec = len(inter)/len(span_set) if span_set else 0\r\n    return rec, inter, h_set\r\n\r\n# compute top 30 hadith with highest recall\r\ntop = []\r\nfor i, h in enumerate(hadith):\r\n    text = h.get('hadithTxt') or h.get('Matn') or ''\r\n    rec, inter, _ = token_recall(text)\r\n    if rec > 0:\r\n        top.append((rec, i, len(inter), inter, h['title'][:80], text[:200]))\r\n\r\ntop_sorted = sorted(top, key=lambda x: (-x[0], -x[2]))\r\ntop_sorted[:10], len(top_sorted)",
