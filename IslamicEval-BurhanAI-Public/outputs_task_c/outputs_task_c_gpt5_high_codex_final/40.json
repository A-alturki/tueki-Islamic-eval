      "id": "ci_689678ee25888197b69198c3aa534bf304cd5b9c258daca8",
      "code": "import re, unicodedata\n\n# Arabic diacritics\narabic_diacritics = re.compile(r\"[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]\")\n\ndef normalize_arabic(s):\n    if not s:\n        return s\n    # remove tatweel\n    s = s.replace('\\u0640', '')\n    # remove diacritics\n    s = arabic_diacritics.sub('', s)\n    # normalize alef forms and hamza?\n    s = re.sub('[\\u0622\\u0623\\u0625\\u0671\\u0672\\u0673\\u0675]', 'ا', s)\n    s = s.replace('ٱ', 'ا')  # alif wasla to alif\n    s = s.replace('ى', 'ي')\n    s = s.replace('ؤ', 'و').replace('ئ', 'ي').replace('ء', 'ء')  # keep hamza?\n    # ta marbuta to ha? maybe keep\n    # unify spaces\n    s = re.sub(r'\\s+', ' ', s)\n    return s.strip()\n\ndef strip_punct(s):\n    return re.sub(r'[^\\w\\s\\u0600-\\u06FF]+', ' ', s)\n\ndef norm_all(s):\n    return normalize_arabic(strip_punct(s or '')).lower()\n\ndef lcs_len(a,b):\n    # longest common substring? Or subsequence?\n    # implement normalized LCS in terms of LCS length / max(len)\n    # We'll do python difflib SequenceMatcher ratio\n    return difflib.SequenceMatcher(None, a, b).ratio()\n\ndef token_f1(a,b):\n    ta = set(a.split())\n    tb = set(b.split())\n    if not ta or not tb:\n        return 0.0\n    prec = len(ta & tb)/len(ta)\n    rec = len(ta & tb)/len(tb)\n    if prec+rec==0:\n        f1=0.0\n    else:\n        f1 = 2*prec*rec/(prec+rec)\n    return f1\n\ndef sim_score(a,b):\n    an = norm_all(a)\n    bn = norm_all(b)\n    # combine ratio and token F1\n    return (lcs_len(an,bn) + token_f1(an,bn))/2\n\nnorm_all(\"وَمَنْ يَتَّقِ اللهَ يَجْعَل لَّهُ مَخْرَجًا وَيَرْزُقْهُ مِنْ حَيْثُ لَا يَحْتَسِبُ\")",
