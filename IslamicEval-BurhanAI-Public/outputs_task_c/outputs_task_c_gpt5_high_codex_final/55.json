      "code": "def normalize_arabic(s):\r\n    if not s:\r\n        return \"\"\r\n    # remove tashkeel\r\n    tashkeel = re.compile(r'[\\u0617-\\u061A\\u064B-\\u0652\\u0657-\\u065F\\u0670\\u06D6-\\u06ED]')\r\n    s = tashkeel.sub('', s)\r\n    # tatweel\r\n    s = s.replace('ـ', '')\r\n    # unify alef forms\r\n    s = re.sub('[إأٱآا]', 'ا', s)\r\n    # unify ya\r\n    s = s.replace('ى', 'ي').replace('ئ', 'ي').replace('ؤ', 'و')\r\n    # hamza on alif? already handled\r\n    # remove punctuation and non-letters\r\n    s = re.sub(r'[^\\u0621-\\u063A\\u0641-\\u064A\\s]', ' ', s)\r\n    # collapse whitespace\r\n    s = re.sub(r'\\s+', ' ', s).strip()\r\n    return s\r\n\r\nnorm_target = normalize_arabic(target)\r\nnorm_target",
