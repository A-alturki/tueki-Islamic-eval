      "id": "ci_689678f4df1081968ffa1006efdce46c0ceafe41c835f0b6",
      "code": "def strip_diacritics(s):\n    return ''.join(ch for ch in unicodedata.normalize('NFD', s) if unicodedata.category(ch) != 'Mn')\n\ndef normalize_ar(s):\n    if s is None:\n        return None\n    s = s.replace('ـ','')  # tatweel\n    s = strip_diacritics(s)\n    # normalize alif variations\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا')\n    s = s.replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\n    s = s.replace('ٱ','ا')\n    # normalize spaces and punctuation\n    s = re.sub(r'[^\\w\\s]', ' ', s)\n    s = re.sub(r'\\s+', ' ', s).strip().lower()\n    return s\n\ndef search_texts(data_list, fieldnames, query_norm):\n    results = []\n    for i, item in enumerate(data_list):\n        for field in fieldnames:\n            txt = item.get(field)\n            if not txt: \n                continue\n            norm = normalize_ar(txt)\n            if query_norm in norm:\n                results.append((i, field, txt))\n                break\n    return results\n\nquery = \"مثل الذين يتركون الأمر بالمعروف والنهي عن المنكر مثل شركاء اللصوص\"\nquery_norm = normalize_ar(query)\nlen(query), query_norm",
