      "code": "# search for entries containing \"شركاء\" and also stems for \"سرق\"\ndef contains_shurka_srq(txt):\n    t = strip_diacritics(txt)\n    return ('شركا' in t or 'شركاء' in t) and ('سرق' in t or 'سارق' in t or 'سرقة' in t or 'سراق' in t)\nmatches=[]\nfor i,item in enumerate(hadith_db):\n    for field in ['hadithTxt','Matn']:\n        txt = item.get(field)\n        if not txt:\n            continue\n        if contains_shurka_srq(txt):\n            matches.append((i, field, txt))\n            break\nlen(matches)",
