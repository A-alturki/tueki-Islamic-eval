      "code": "# compute ratio with Matn if present else hadithTxt\ndef get_text(item):\n    return item.get('Matn') if item.get('Matn') else item.get('hadithTxt')\n\ntop = []\nfor item in hadith_db:\n    txt = get_text(item)\n    if not txt:\n        continue\n    n = normalize_ar(txt)\n    # quick filter: must share at least the word 'مثل' or 'معروف' or 'المنكر' or 'اللصوص' \n    # else skip to save compute\n    if any(word in n for word in ['مثل','معروف','منكر','اللصوص','اللص','شركاء']):\n        sim = ratio(query_norm, n)\n        top.append((sim, txt))\n        \ntop_sorted = sorted(top, key=lambda x: x[0], reverse=True)[:20]\n[(round(sim,3), t[:120].replace('\\n',' ')[:120]) for sim,t in top_sorted[:10]]",
