      "id": "ci_68967916bd708195944dc8d95568f70e02a9e55986657a9e",
      "code": "import re, unicodedata, math, statistics, difflib\nfrom collections import defaultdict, Counter\n\norig_span = \"وَأَخَذْنَا مِن بَنِي إِسْرَائِيلَ بَعْضَ الْحُدُودِ\"\nsnippet = \"وَأَخَذْنَ...الْحُدُودِ\"\n\n# normalization\narabic_diacritics = re.compile(r'[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]')\ntatweel = '\\u0640'\npunc_regex = re.compile(r'[^\\w\\s\\u0600-\\u06FF]')  # keep arabic letters and digits and whitespace\nspaces = re.compile(r'\\s+')\n\ndef normalize_ar(s):\n    s = s.replace(tatweel, '')\n    s = arabic_diacritics.sub('', s)\n    # unify hamza forms\n    s = s.replace('أ', 'ا').replace('إ', 'ا').replace('آ', 'ا').replace('ؤ', 'و').replace('ئ', 'ي').replace('ة', 'ه')\n    # remove punctuation\n    s = punc_regex.sub(' ', s)\n    # collapse spaces\n    s = spaces.sub(' ', s).strip()\n    return s\n\nnorm_orig = normalize_ar(orig_span)\nnorm_orig",
