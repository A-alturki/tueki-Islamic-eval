      "id": "ci_68967e9427508196b9578b0a926d0d0804144104bf83219f",
      "code": "import re, unicodedata\n\narabic_diacritics = re.compile(r'[\\u0610-\\u061a\\u064b-\\u065f\\u06d6-\\u06ed]')\ntatweel = '\\u0640'\n\ndef normalize_ar(text):\n    # remove tatweel and diacritics, unify hamza forms\n    t = text.replace(tatweel, '')\n    t = arabic_diacritics.sub('', t)\n    # unify hamza-alef variants\n    t = re.sub('[\\u0622\\u0623\\u0625]', 'ا', t)  # alef with hamza/ madda to bare alif\n    t = t.replace('ى', 'ي').replace('ة', 'ه')\n    # remove punctuation and non-letters\n    t = re.sub(r'[^\\w\\s]', ' ', t, flags=re.UNICODE)\n    # collapse whitespace\n    t = re.sub(r'\\s+', ' ', t).strip().lower()\n    return t\n\ndef lcs(a, b):\n    # compute LCS length\n    n, m = len(a), len(b)\n    dp = [0]*(m+1)\n    for i in range(1, n+1):\n        prev = 0\n        for j in range(1, m+1):\n            tmp = dp[j]\n            if a[i-1]==b[j-1]:\n                dp[j] = prev + 1\n            else:\n                dp[j] = max(dp[j], dp[j-1])\n            prev = tmp\n    return dp[m]\n\ndef lcs_ratio(a, b):\n    # normalized LCS length / avg length\n    L = lcs(a, b)\n    avg = (len(a)+len(b))/2 if (len(a)+len(b))>0 else 1\n    return L/avg\n\nfull_substring = \"ادفع السيئة بالحسنة. ذلك خير وأفضل بالفعل\"\nsnippet = \"ادفع السيئ...ضل بالفعل\"\n\nn_full = normalize_ar(full_substring)\nn_cand = normalize_ar(ayah_text)\nn_snip = normalize_ar(snippet)\n\nlcs_full = lcs_ratio(n_full, n_cand)\nlcs_snip = lcs_ratio(n_snip, n_cand)\nn_full, n_cand, lcs_full, lcs_snip",
      "container_id": "cntr_68967e4a1c3c8190bb42c1bb9738519702e64b0ce7e05148",
