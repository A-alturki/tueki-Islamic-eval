      "id": "ci_6896727d46f881939055fe66a0fd7acb09343a4055a49178",
      "code": "def norm(s):\n    # remove diacritics and tatweel, unify hamza forms, remove punctuation\n    s = s.replace('ـ','')\n    s = ''.join(ch for ch in s if unicodedata.category(ch) != 'Mn')\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ٰ','')\n    s = re.sub(r'[^\\w\\s]', ' ', s)\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\ntargets = [\"ولا تسرف في الاموال\",\"ولا تسرفوا\",\"الاموال اسراف\",\"تبذير\",\"ولا تبذر\"]\nres=[]\nfor v in q:\n    n=norm(v['ayah_text'])\n    if any(t in n for t in targets):\n        res.append(v)\nlen(res)",
      "container_id": "cntr_6896726f53a481909df581228cc73ca908d71f8319586f1a",
      "outputs": null,
      "status": "completed",
      "type": "code_interpreter_call"
