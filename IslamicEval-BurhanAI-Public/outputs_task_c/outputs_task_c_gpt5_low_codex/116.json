      "code": "# compute similarity ratios\ndef best_matches(q, topn=10):\n    qn=normalize_ar(q)\n    scores=[]\n    for rec in qdata:\n        tn=normalize_ar(rec['ayah_text'])\n        ratio=difflib.SequenceMatcher(None, qn, tn).ratio()\n        scores.append((ratio, rec))\n    scores.sort(reverse=True, key=lambda x:x[0])\n    return scores[:topn]\n\ntop=best_matches(query_full, 20)\n[(round(s,3), r['surah_name'], r['ayah_id'], r['ayah_text'][:60]) for s,r in top[:10]]",
