      "id": "ci_68967280e3f88195ba48cb577971cb15085b67ded6075dca",
      "code": "def normalize_ar(s):\n    s=str(s)\n    # remove diacritics\n    s=re.sub(r'[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]', '', s)\n    # tatweel\n    s=s.replace('ـ','')\n    # normalize alef forms\n    s=re.sub('[إأٱآا]', 'ا', s)\n    # yaa/alif maqsura\n    s=s.replace('ى','ي')\n    # ta marbuta to ha?\n    # Keep ة as ه? Better to unify to ه\n    s=s.replace('ة','ه')\n    # waw hamza etc normalize hamza on waw/ya to just ء? \n    s=s.replace('ؤ','ء').replace('ئ','ء').replace('ء','ء')\n    # remove punctuation\n    s=re.sub(r'[^\\u0621-\\u064A0-9\\s]', ' ', s)\n    s=re.sub(r'\\s+',' ', s).strip()\n    return s\n\nquery_full=\"وَمَن يَقُلْ لِوَليٍّ هَذَا عَقِدَ لِيَ عَلَيْهِمْ عُقْدَةً مِنَ اللَهِ\"\nqnorm=normalize_ar(query_full)\nqnorm",
