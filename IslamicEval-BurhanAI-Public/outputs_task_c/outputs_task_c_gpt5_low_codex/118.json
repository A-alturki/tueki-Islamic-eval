      "code": "def normalize(s):\n    # remove diacritics\n    import re, unicodedata\n    s = re.sub(r'[ـ]', '', s) # tatweel\n    # unify hamza forms maybe later\n    # remove tashkeel\n    arabic_diacritics = re.compile('[\\u0617-\\u061A\\u064B-\\u0652\\u0670\\u06D6-\\u06ED]')\n    s = re.sub(arabic_diacritics, '', s)\n    s = s.replace('ٱ','ا')\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا')\n    s = s.replace('ى','ي')\n    s = s.replace('ؤ','و').replace('ئ','ي')\n    # remove punctuation\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]', ' ', s)\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\nsnippet_full=\"وَلا تَقُل لَّم أَجِدْ شَيْئًا\"\nnorm_snip=normalize(snippet_full)\nnorm_snip",
