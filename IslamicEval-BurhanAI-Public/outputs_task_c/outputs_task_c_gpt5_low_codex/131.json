      "id": "ci_689672851bec81939ca76f5e2535fc080bab5241b296fdf3",
      "code": "def normalize(s):\n    if s is None:\n        return ''\n    # remove tashkeel\n    tashkeel = ''.join(chr(c) for c in range(0x0610, 0x061B+1)) + ''.join(chr(c) for c in range(0x064B, 0x065F+1)) + ''.join(chr(c) for c in range(0x0670, 0x0670+1)) + ''.join(chr(c) for c in range(0x06D6, 0x06ED+1))\n    s = re.sub(f\"[{re.escape(tashkeel)}]\", \"\", s)\n    # tatweel\n    s = s.replace(\"ـ\",\"\")\n    # unify hamza\n    s = re.sub(\"[إأآا]\", \"ا\", s)\n    s = re.sub(\"ى\", \"ي\", s)\n    s = re.sub(\"ؤ\", \"و\", s)\n    s = re.sub(\"ئ\", \"ي\", s)\n    # punctuation\n    s = re.sub(r\"[^\\w\\s\\u0600-\\u06FF]\", \" \", s)\n    s = re.sub(r\"\\s+\", \" \", s).strip()\n    return s\n\ntarget_full=\"من عمل عملاً جنسياً مثلياً فقد ارتكب خطيئة كبيرة\"\ntarget_snip=\"من عمل عمل...طيئة كبيرة\"\nnorm_full=normalize(target_full)\nnorm_full",
      "container_id": "cntr_6896726f0b0c81908685a390b253ffba071959c86b205def",
      "outputs": null,
      "status": "completed",
      "type": "code_interpreter_call"
    },
    {
      "id": "ci_68967289bbd881938f6b96d9184cd3920bab5241b296fdf3",
      "code": "def search_hadith(query, topn=20):\n    nq=normalize(query)\n    results=[]\n    for rec in hadith:\n        matn=rec.get('hadithTxt') or rec.get('Matn') or ''\n        nm=normalize(matn)\n        if nq in nm:\n            results.append((1.0, matn, rec))\n        else:\n            ratio=difflib.SequenceMatcher(None, nq, nm).ratio()\n            # also token overlap\n            qset=set(nq.split())\n            overlap=len(qset & set(nm.split()))/max(1,len(qset))\n            score=0.5*ratio+0.5*overlap\n            results.append((score, matn, rec))\n    results.sort(key=lambda x:x[0], reverse=True)\n    return results[:topn]\n\nres=search_hadith(target_full, topn=5)\n[(r[0], r[1][:120]) for r in res]",
      "container_id": "cntr_6896726f0b0c81908685a390b253ffba071959c86b205def",
      "outputs": null,
      "status": "completed",
      "type": "code_interpreter_call"
