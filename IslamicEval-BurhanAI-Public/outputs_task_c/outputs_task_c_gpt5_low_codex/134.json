      "code": "def normalize(s):\n    if not s:\n        return ''\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]+',' ',s)\n    s = ''.join(c for c in s if unicodedata.category(c)!='Mn') # remove diacritics\n    s = s.replace('ٱ','ا').replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ۃ','ه').replace('ة','ه')\n    s = re.sub(r'\\s+',' ',s).strip()\n    return s\n\ntarget = \"ما أذن الله لشيء ما أذن لنبي في الترنم بالقرآن\"\nnorm_target = normalize(target)\nnorm_target",
