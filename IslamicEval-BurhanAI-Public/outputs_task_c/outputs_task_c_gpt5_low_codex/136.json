      "code": "# define normalization\nimport re, unicodedata\ndef normalize(s):\n    if s is None: \n        return \"\"\n    s=str(s)\n    s=re.sub(r'[^\\w\\s\\u0600-\\u06FF]', ' ', s)  # remove punctuation\n    # remove diacritics\n    s=''.join(ch for ch in unicodedata.normalize('NFKD', s) if not unicodedata.combining(ch))\n    # unify alef/hamza/ya/ta marbuta\n    s=s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ى','ي').replace('ة','ه').replace('ؤ','و').replace('ئ','ي')\n    s=re.sub(r'\\s+',' ',s).strip()\n    return s\n\nsnippet=\"فينادي، فيقول: من يدعوني فأستجيب له، من يسألني فأعطيه، من يستغفرني فأغفر له\"\nnorm_snip=normalize(snippet)\nnorm_snip",
