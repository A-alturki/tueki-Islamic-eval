    {
      "id": "ci_689672c009648197a9f8cc382e00420c0a08313392b37ad5",
      "code": "# Try searching by a shorter distinctive segment\nfor q in [\"اقرءوا القرآن بلحون العرب\", \"لا يجاوز حناجرهم مفتونة قلوبهم\", \"ترجيع الغناء والرهبانية والنوح\", \"لحون اهل الفسق\", \"بلحون العرب واصواتها\"]:\n    res = search_in_hadith(normalize_ar(q))\n    print(q, len(res))",
