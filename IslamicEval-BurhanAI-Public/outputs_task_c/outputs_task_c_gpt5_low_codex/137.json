      "id": "ci_689672adf5608197b1b2c1946187e6a70a08313392b37ad5",
      "code": "def normalize_ar(s):\n    # remove tashkeel, tatweel, punctuation, normalize alif/hamza/ya/ta marbuta\n    s = ''.join(ch for ch in s if not unicodedata.category(ch).startswith('M'))\n    s = re.sub('[\\u0640]', '', s)  # tatweel\n    # normalize hamza forms\n    s = re.sub('[\\u0622\\u0623\\u0625]', 'ا', s)\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا')\n    s = s.replace('ى','ي')\n    s = s.replace('ؤ','و').replace('ئ','ي')\n    s = s.replace('ة','ه')\n    # remove punctuation\n    s = re.sub(r'[^\\w\\s]', ' ', s)\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\nsnippet_full = \"اقرءوا القرآن بلحون العرب وأصواتها، وإياكم ولحون أهل الفسق وأهل الكتابين، وسيجىء قوم من بعدى يرجعون بالقرآن ترجيع الغناء والرهبانية والنوح، لا يجاوز حناجرهم مفتونة قلوبهم وقلوب الذين يعجبهم شأنهم\"\nnorm_target = normalize_ar(snippet_full)\nnorm_target[:200], len(norm_target)",
      "container_id": "cntr_689672790eec8190a4f61362d20fac8804b2fdab08686391",
      "outputs": null,
      "status": "completed",
      "type": "code_interpreter_call"
    },
    {
