    {
      "id": "ci_6896729077488197bdf663f75362cae90026e4e50372cc2e",
      "code": "def norm(s):\n    # remove diacritics and tatweel and punctuation; unify hamza?\n    s2=''.join(ch for ch in s if ch not in '\\u0640')  # remove tatweel\n    # remove harakat\n    harakat = ''.join(chr(c) for c in range(0x0610,0x061A+1))+''.join(chr(c) for c in range(0x064B,0x065F+1))+''.join(chr(c) for c in range(0x0670,0x0670+1))\n    s2=''.join(ch for ch in s2 if ch not in harakat)\n    # normalize alef forms\n    s2=s2.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ٱ','ا')\n    # remove punctuation\n    s2=re.sub(r'[^\\w\\s]', ' ', s2)\n    s2=re.sub(r'\\s+',' ', s2).strip()\n    return s2\n\ntarget_full=\"وَلَقَدْ أَرْسَلْنَا مِن قَبْلِكَ رُسُلًا إِلَى قَوْمِهِمْ فَزادَهُمْ عُضَالًا وَجَزَعًا\"\ntarget_norm=norm(target_full)\ntarget_norm[:200]",
      "container_id": "cntr_6896726f35d08190870818549c9c237201e31fddf5b7f92d",
      "outputs": null,
      "status": "completed",
      "type": "code_interpreter_call"
    },
    {
