      "code": "# search for normalized text containing \"لا تشرك بالله إن الشرك لظلم عظيم\"\ndef normalize(s):\n    # remove diacritics\n    s=''.join(ch for ch in s if unicodedata.category(ch)!='Mn')\n    # remove tatweel\n    s=s.replace('ـ','')\n    # unify hamza forms\n    s=re.sub('[أإآا]', 'ا', s)\n    s=re.sub('[ى]', 'ي', s)\n    # remove punctuation\n    s=re.sub(r'[^\\w\\s]', ' ', s)\n    # collapse spaces\n    s=re.sub(r'\\s+',' ', s).strip()\n    return s\n\ntarget_norm = normalize(\"لا تشرك بالله إن الشرك لظلم عظيم\")\ncands=[]\nfor rec in quran:\n    n=normalize(rec['ayah_text'])\n    if target_norm in n:\n        cands.append(rec)\nlen(cands)",
