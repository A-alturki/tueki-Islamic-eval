      "code": "# build normalized search\r\ndef normalize(s):\r\n    # remove diacritics\r\n    s = ''.join(ch for ch in unicodedata.normalize('NFD', s) if not unicodedata.combining(ch))\r\n    # remove tatweel and punctuation\r\n    s = s.replace('ـ','')\r\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]', ' ', s)\r\n    # unify hamza forms\r\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\r\n    # collapse spaces\r\n    s = re.sub(r'\\s+',' ', s).strip()\r\n    return s\r\n\r\nnorm_needle = normalize(\"ولقد أرسلنا نوحا إلى قومه\")\r\nmatches = []\r\nfor a in q:\r\n    if normalize(a['ayah_text']).find(norm_needle)>=0:\r\n        matches.append(a)\r\nlen(matches), [(m['surah_name'], m['ayah_id']) for m in matches[:10]]",
