      "code": "def normalize(s):\n    if s is None: return \"\"\n    # remove tashkeel\n    s = re.sub(r'[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]', '', s)\n    # remove tatweel\n    s = s.replace('\\u0640','')\n    # unify alef forms\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ٱ','ا')\n    # remove punctuation and non-letters/digits/space\n    s = re.sub(r'[^\\w\\s]', ' ', s, flags=re.UNICODE)\n    # normalize spaces\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\ntarget_full=\"لا تَزَوَّجَنَّ شُرَّعَتكَ\"\ntarget_snip=\"لا تَزَوَّ...شُرَّعَتكَ\"\nnorm_full=normalize(target_full)\nnorm_full",
