      "code": "# define normalization: remove tashkeel, tatweel, punctuation, unify hamza\nimport re\narabic_diacritics = re.compile('[\\u0610-\\u061A\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]')\ndef normalize(s):\n    if s is None:\n        return ''\n    s = re.sub('[\\u0640]', '', s)  # tatweel\n    s = arabic_diacritics.sub('', s)\n    # unify hamza forms to bare alif\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\n    # remove punctuation and extra spaces\n    s = re.sub(r'[^\\w\\s]', ' ', s)\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\nquery_full = \"لا تُوطَأُ حاملٌ حتى تَضَعَ حَمْلَها، ولا غيرُ ذاتِ حَمْلٍ حتى تَطْهُرَ من دَمِ حَيْضَتِها\"\nnq = normalize(query_full)\nnq[:120], nq",
