    {
      "id": "ci_68967292d87c8194aeac8c1d2ad0c24500768da6d6830aa8",
      "code": "# search for \"اخاك\" token with imperative prohibition maybe \"لا تتزوج\"?\nterms=[\"اخاك\",\"اخا\",\"اخيك\",\"باخيك\",\"اخيه\"]\nhits=[]\nfor rec in had:\n    n=normalize((rec.get('hadithTxt') or rec.get('Matn') or ''))\n    if any(t in n.split() for t in terms):\n        hits.append((rec['hadithID'], n[:120]))\nlen(hits)",
