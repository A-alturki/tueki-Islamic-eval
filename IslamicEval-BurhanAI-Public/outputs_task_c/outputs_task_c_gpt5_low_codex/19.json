    {
      "id": "ci_6896728762fc8194b44ececf13a56a3100768da6d6830aa8",
      "code": "def normalize(s):\n    if s is None:\n        return \"\"\n    # remove tashkeel\n    s=re.sub(r'[\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]', '', s)\n    # normalize hamza variants\n    s=s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ة','ه').replace('ى','ي')\n    # remove tatweel and punctuation\n    s=re.sub(r'[^\\w\\s]', ' ', s)\n    s=re.sub(r'[_]', ' ', s)\n    s=re.sub(r'\\s+',' ', s).strip()\n    return s\nneedle=\"لا تَزَوَّجَنَّ أَخاكَ\"\nnorm_needle=normalize(needle)\nnorm_needle",
      "container_id": "cntr_6896726f619c8190ad2147ac5bd4d4270d89ff33c2513782",
      "outputs": null,
      "status": "completed",
      "type": "code_interpreter_call"
    },
    {
      "id": "ci_6896728b0ec48194b98a0f24c26f8c0700768da6d6830aa8",
      "code": "matches=[]\nfor rec in had:\n    txt = rec.get('hadithTxt') or rec.get('Matn') or ''\n    if not txt: \n        continue\n    if norm_needle in normalize(txt):\n        matches.append(txt)\nlen(matches)",
      "container_id": "cntr_6896726f619c8190ad2147ac5bd4d4270d89ff33c2513782",
      "outputs": null,
      "status": "completed",
      "type": "code_interpreter_call"
