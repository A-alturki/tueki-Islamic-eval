      "code": "def normalize(s):\n    # remove diacritics and tatweel, punctuation, normalize hamza\n    if s is None:\n        return ''\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]', ' ', s)\n    s = re.sub('[\\u0640]', '', s)  # tatweel\n    # unify hamza forms\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\n    # remove harakat\n    s = ''.join(ch for ch in s if unicodedata.category(ch) != 'Mn')\n    s = re.sub(r'\\s+',' ', s).strip()\n    return s\nneedle = \"لا تَزَوَّجَنَّ شُرَّعَتكَ\"\nnorm_needle = normalize(needle)\nnorm_needle",
      "container_id": "cntr_6896726f29548190a985a232490b26ed06420fbf775d1b3c",
