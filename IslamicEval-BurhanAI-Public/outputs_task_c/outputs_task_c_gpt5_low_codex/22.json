      "code": "# Define normalization function\nimport re, unicodedata\n\ndef normalize_ar(s):\n    if s is None: return \"\"\n    # remove tashkeel\n    s = re.sub(r'[\\u0617-\\u061A\\u064B-\\u0652\\u0657-\\u065F\\u0670\\u06D6-\\u06ED]', '', s)\n    # remove tatweel\n    s = s.replace('\\u0640','')\n    # unify hamza forms\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ٱ','ا')\n    # remove punctuation\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]', ' ', s)\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\ntarget = \"لا تَزَوَّجَنَّ أُختَيَّ\"\nnorm_target = normalize_ar(target)\nnorm_target",
