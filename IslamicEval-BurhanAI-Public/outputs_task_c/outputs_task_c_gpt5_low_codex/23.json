      "id": "ci_6896728940c48193801e2e0c5766294d0de46127a2a700a3",
      "code": "def norm(s):\n    if not s: return \"\"\n    # remove diacritics\n    s = ''.join(ch for ch in s if unicodedata.category(ch) != 'Mn')\n    # unify alef/hamza\n    s = re.sub('[إأٱآا]', 'ا', s)\n    s = re.sub('ى', 'ي', s)\n    s = re.sub('ؤ', 'و', s)\n    s = re.sub('ئ', 'ي', s)\n    s = re.sub('ة', 'ه', s)\n    # remove tatweel and punctuation\n    s = s.replace('ـ','')\n    s = re.sub(r'[^\\w\\s]', ' ', s)\n    # collapse spaces\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\nquery = \"لا تَزَوَّجَنَّ شُرَّعَتكَ\"\nnq = norm(query)\nnq",
      "container_id": "cntr_6896726fad788190a2b52175762cf9980c2ce2f98c28e4e0",
