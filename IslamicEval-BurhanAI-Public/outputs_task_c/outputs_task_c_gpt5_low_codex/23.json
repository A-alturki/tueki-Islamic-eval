      "code": "# Search hadith texts for this normalized substring\nmatches=[]\nfor i,rec in enumerate(hadith_data):\n    text = rec.get('hadithTxt') or rec.get('Matn') or \"\"\n    if not text: continue\n    if norm(text).find(nq) != -1:\n        matches.append((i, text))\nlen(matches)",
