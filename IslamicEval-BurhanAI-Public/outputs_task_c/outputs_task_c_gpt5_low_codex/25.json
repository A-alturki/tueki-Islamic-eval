      "code": "def normalize(s):\n    if not s: return ''\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]+', ' ', s)\n    s = re.sub(r'[\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]', '', s) # remove diacritics and marks\n    s = re.sub(r'[ـ]', '', s) # tatweel\n    # unify hamza forms\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\n    s = re.sub(r'\\s+',' ', s).strip()\n    return s\n\nquery = \"لا تَزَوَّجَنَّ أَخاكَ\"\nnq = normalize(query)\nnq",
