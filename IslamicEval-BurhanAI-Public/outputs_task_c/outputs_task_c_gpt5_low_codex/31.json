      "id": "ci_6896728049308193b4577a92186c036d0bcffb229e0da861",
      "code": "def normalize(s):\n    if s is None:\n        return \"\"\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]', ' ', s)\n    # remove diacritics\n    s = ''.join(ch for ch in unicodedata.normalize('NFD', s) if unicodedata.category(ch) != 'Mn')\n    # unify alef forms\n    s = re.sub('[إأآا]', 'ا', s)\n    s = s.replace('ؤ','و').replace('ئ','ي').replace('ة','ه').replace('ى','ي')\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\nquery = \"إنما بعثت لأتمم مكارم الأخلاق\"\nnorm_query = normalize(query)\nnorm_query",
      "container_id": "cntr_6896726fe3d88190a71b7c298ed309ab076f3fd7958effc3",
