      "id": "ci_6896728e9ee88190b68aae6eb8f301930a9b9cba3d401f0d",
      "code": "# Define normalize function\r\ndef normalize_ar(s):\r\n    if s is None: \r\n        return \"\"\r\n    # remove tashkeel\r\n    tashkeel = ''.join(chr(c) for c in range(0x0610, 0x061A+1)) + ''.join(chr(c) for c in range(0x064B, 0x065F+1)) + ''.join(chr(c) for c in range(0x0670, 0x0670+1)) + ''.join(chr(c) for c in range(0x06D6, 0x06ED+1))\r\n    s = ''.join(ch for ch in s if ch not in tashkeel)\r\n    # remove tatweel\r\n    s = s.replace('ـ','')\r\n    # unify hamza/aleph forms\r\n    s = re.sub('[أإآٱ]', 'ا', s)\r\n    # normalize ya/ta marbuta/ha\r\n    s = s.replace('ى','ي')\r\n    # remove punctuation\r\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]', ' ', s)\r\n    # collapse spaces\r\n    s = re.sub(r'\\s+', ' ', s).strip()\r\n    return s\r\n\r\nsnippet = \"فانكحوا ما طاب لكم من النساء مثنى وثلاث ورباع\"\r\nnorm_snip = normalize_ar(snippet)\r\nnorm_snip",
      "container_id": "cntr_6896726ff6708190b55915696f389ab10614f9644a2cea9d",
