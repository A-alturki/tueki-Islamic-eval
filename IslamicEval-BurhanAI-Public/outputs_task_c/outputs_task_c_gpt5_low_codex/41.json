      "code": "def normalize(s):\n    if s is None:\n        return ''\n    # remove diacritics\n    s = ''.join(c for c in unicodedata.normalize('NFD', s) if unicodedata.category(c) != 'Mn')\n    # normalize Arabic letters\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ۃ','ه').replace('ة','ه')\n    # remove tatweel and punctuation\n    s = re.sub(r'[^\\w\\s]', ' ', s)\n    s = s.replace('ـ',' ')\n    s = re.sub(r'\\s+',' ', s).strip()\n    return s\nneedle = \"لا يؤمن أحدكم حتى يكون هواه تبعًا لما جئت به\"\nn_norm = normalize(needle)\nn_norm",
