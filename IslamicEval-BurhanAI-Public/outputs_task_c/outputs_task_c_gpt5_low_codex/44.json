      "code": "def normalize(s):\n    if not s:\n        return \"\"\n    # remove tashkeel\n    s = re.sub(r'[\\u0617-\\u061A\\u064B-\\u0652\\u0670\\u0657-\\u065F\\u06D6-\\u06ED]', '', s)\n    # remove tatweel and punctuation\n    s = s.replace('ـ','')\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]', ' ', s)\n    # unify hamza forms\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\n    # collapse spaces\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\nquery = \"لا يؤمن أحدكم حتى يكون هواه تبعًا لما جئت به\"\nnorm_query = normalize(query)\nnorm_query\n",
