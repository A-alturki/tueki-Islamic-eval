      "code": "# function to normalize\nimport re, unicodedata\ndef normalize(s):\n    if s is None:\n        return \"\"\n    s = re.sub(r'[\\u064B-\\u065F\\u0670\\u06D6-\\u06ED]', '', s)  # remove harakat, small alef etc\n    s = re.sub(r'[ـ]', '', s)  # tatweel\n    s = s.replace('إ','ا').replace('أ','ا').replace('آ','ا').replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\n    s = re.sub(r'[^\\w\\s]', ' ', s)  # remove punctuation\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\ntarget = \"لا يؤمن أحدكم حتى يكون هواه تبعًا لما جئت به\"\nnorm_target = normalize(target)\nnorm_target",
