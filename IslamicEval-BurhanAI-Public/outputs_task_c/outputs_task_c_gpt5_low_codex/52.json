      "code": "# search for phrases\ndef norm(s):\n    # remove diacritics, tatweel, punctuation, normalize alif/hamza forms, ya/aleff maksura\n    s = ''.join(c for c in s if c != 'ـ')  # tatweel\n    # remove diacritics\n    s = ''.join(ch for ch in unicodedata.normalize('NFD', s) if unicodedata.category(ch) != 'Mn')\n    # unify alifs\n    s = s.replace('إ','ا').replace('أ','ا').replace('آ','ا')\n    s = s.replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\n    # remove punctuation and spaces normalize\n    s = re.sub(r'[^\\w\\s]', ' ', s)\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\ntargets = [\"ثُمَّ سَوَّاهُ وَنَفَخَ فِيهِ مِنْ رُوحِهِ\",\"فَإِذَا سَوَّيْتُهُ وَنَفَخْتُ فِيهِ مِنْ رُوحِي\",\"نَفَخَ فِيهِ مِنْ رُوحِهِ\"]\nnorm_targets=[norm(t) for t in targets]\ncands=[]\nfor rec in q:\n    n=norm(rec['ayah_text'])\n    for t in norm_targets:\n        if t in n:\n            cands.append(rec)\nlen(cands)",
      "container_id": "cntr_6896726f3638819086e4d38d41be43430750eb24c510e6ef",
