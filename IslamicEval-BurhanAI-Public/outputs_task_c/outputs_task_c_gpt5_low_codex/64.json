      "code": "import json, re, unicodedata, sys, textwrap, os, itertools\r\n\r\nquran_path = \"/mnt/data/file-RhatJL6W5hpishQfBLfQ2a-quranic_verses.json\"\r\nwith open(quran_path, 'r', encoding='utf-8') as f:\r\n    q = json.load(f)\r\n\r\ndef normalize(s):\r\n    # remove diacritics\r\n    s2 = ''.join(ch for ch in s if not unicodedata.combining(ch))\r\n    s2 = unicodedata.normalize('NFKD', s2)\r\n    # unify hamza forms: replace alif variants\r\n    s2 = s2.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ٰ','')\r\n    # remove tatweel and punctuation\r\n    s2 = s2.replace('ـ','')\r\n    s2 = re.sub(r'[^\\w\\s\\u0600-\\u06FF]+',' ', s2)\r\n    s2 = re.sub(r'\\s+',' ', s2).strip()\r\n    return s2\r\n\r\ndef search_phrase(phrase):\r\n    n = normalize(phrase)\r\n    hits = []\r\n    for rec in q:\r\n        t = rec.get('ayah_text','')\r\n        if n in normalize(t):\r\n            hits.append(t)\r\n    return hits\r\n\r\n# search occurrences of 'بالطور أمدا' and 'الطور أمدا' and 'امدا'\r\nfor ph in [\"بالطور أمداً\",\"بالطور أمدا\",\"الطور أمدا\",\"الطور أمداً\",\"أمداً\",\"بالطور\",\"أمدا\"]:\r\n    hits = search_phrase(ph)\r\n    print(\"PH:\", ph, \"hits:\", len(hits))\r\n    for h in hits[:10]:\r\n        print(h)",
