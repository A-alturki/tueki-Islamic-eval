      "code": "def normalize_ar(s):\n    # remove tashkeel and tatweel and punctuation, unify alifs/hamzas/ya\n    s = re.sub(r'[ًٌٍَُِّْـ]', '', s)\n    s = re.sub(r'[“”\"\\'«»،؛:.,!؟…\\-–—()\\[\\]{}<>]', ' ', s)\n    s = s.replace('ٰ','')\n    # unify alifs\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا')\n    s = s.replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ۀ','ه')\n    s = re.sub(r'\\s+',' ', s).strip()\n    return s\norig = \"وَإِذْ قَالَ لَهُمْ رُسُلُهُمْ يَا قَوْمِ إِنَّ رَسُولَ اللَّهِ يَأْتِيَكُمْ لِيُجْزِزَ لَكُمْ عُقُدَاتِكُمْ ۚ وَلِيُخْرِجَ الَّذِينَ يُزَكِّيكُمْ وَيُطَهِّرُكُمْ ۚ وَيُعَلِّمُكُمْ مِنْ آيَاتِ اللَّهِ وَيُعَلِّمُكُمْ الْحِكْمَةَ وَيُعَلِّمُكُمْ مِنْ أَمْرِ اللَّهِ وَيُخْرِجُ عَنْكُمْ رِجَالًا وَجُنَّةً ۖ وَيُدَخِلُ عَلَيْكُمْ رِجَالًا ۗ وَاللَّهُ بَصِيرٌ بِالْعِبَادِ ۚ\"\nnorm_orig = normalize_ar(orig)\nnorm_orig[:120]",
