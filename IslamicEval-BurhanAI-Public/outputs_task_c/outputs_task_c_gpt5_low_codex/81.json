      "id": "ci_68967285363081938b1fdb56d973179d015375f1d44da88f",
      "code": "def normalize(s):\n    if s is None: return None\n    # remove diacritics\n    s2=''.join(ch for ch in unicodedata.normalize('NFD', s) if unicodedata.category(ch)!='Mn')\n    # remove tatweel and punctuation-like\n    s2=re.sub(r'[ـ،؛…“”\"\\'«»\\[\\]\\(\\)\\{\\}<>]', ' ', s2)\n    s2=re.sub(r'[^\\w\\s\\u0600-\\u06FF]', ' ', s2)\n    s2=re.sub(r'\\s+', ' ', s2).strip()\n    # unify hamza forms to alif?\n    s2=s2.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ة','ه').replace('ى','ي')\n    return s2\n\ntarget=\"بينما رجل يجر إزاره إذ خسف به، فهو يتجلجل في الأرض إلى يوم القيامة\"\nnorm_target=normalize(target)\nnorm_target",
      "container_id": "cntr_6896726f81c88190aa87042b9c9402520005958d4e48cacf",
      "outputs": null,
      "status": "completed",
