      "id": "ci_6896728d4e248193add68ec91a9c8fcc015375f1d44da88f",
      "code": "cands=[]\nfor rec in hadith:\n    text = rec.get('hadithTxt') or ''\n    matn = rec.get('Matn') or ''\n    for field, s in [('hadithTxt',text),('Matn',matn)]:\n        if not s: continue\n        if 'يتجلجل' in s or 'يجر إزاره' in s or 'خسف' in s:\n            cands.append((rec['hadithID'], field, s))\nlen(cands)",
      "container_id": "cntr_6896726f81c88190aa87042b9c9402520005958d4e48cacf",
