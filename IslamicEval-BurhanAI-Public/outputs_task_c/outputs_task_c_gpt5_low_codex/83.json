      "code": "def norm(s):\n    # remove diacritics\n    s2=''.join(ch for ch in unicodedata.normalize('NFKD', s) if not unicodedata.combining(ch))\n    # remove tatweel and punctuation\n    s2 = re.sub(r'[^\\w\\s\\u0600-\\u06FF]', ' ', s2)\n    s2 = s2.replace('ـ','')\n    # normalize hamza forms\n    s2 = s2.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ة','ه').replace('ى','ي')\n    s2 = re.sub(r'\\s+',' ', s2).strip()\n    return s2\n\ntarget = \"ولقد أرسلنا شعيبًا إلى قومه فقال يا قوم اعبدوا الله ما لكم من إله غيره قد جاءتكم بينة من ربكم فأوفوا الكيل والميزان ولا تبخسوا الناس أشياءهم ولا تفسدوا في الأرض بعد إصلاحها ذلكم خير لكم إن كنتم مؤمنين\"\nn_target = norm(target)\ncands=[]\nfor v in q:\n    if norm(v['ayah_text']).startswith(n_target) or n_target in norm(v['ayah_text']):\n        cands.append(v)\nlen(cands)",
