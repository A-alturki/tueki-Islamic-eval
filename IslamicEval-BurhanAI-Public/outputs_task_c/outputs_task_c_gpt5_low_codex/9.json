      "code": "def normalize(s):\n    if not isinstance(s,str): return ''\n    s = re.sub('[\\u0640]', '', s)  # tatweel\n    # unify hamza: alif variants to alif\n    s = re.sub('[\\u0622\\u0623\\u0625]', '\\u0627', s)\n    s = re.sub('[\\u064B-\\u0652]', '', s)  # remove tashkeel\n    s = re.sub('[\\u0670]', '', s)  # superscript alif\n    s = re.sub('[\\u06D6-\\u06ED]', '', s)  # quranic marks\n    s = re.sub('[^\\w\\s\\u0600-\\u06FF]', ' ', s)\n    s = re.sub('\\s+', ' ', s).strip()\n    return s\nsnippet = \"لا تَزَوَّجَنَّ شُرَّعَتكَ\"\nnorm_snip = normalize(snippet)\nnorm_snip",
