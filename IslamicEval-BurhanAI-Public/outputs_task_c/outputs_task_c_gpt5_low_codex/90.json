      "code": "def normalize(s):\n    # remove tashkeel and tatweel, unify hamza forms, remove punctuation\n    if s is None: return ''\n    s = ''.join(ch for ch in s if ch != 'ـ')\n    # remove harakat\n    harakat = ''.join(chr(c) for c in range(0x0610,0x061B)) + ''.join(chr(c) for c in range(0x064B,0x065F)) + '\\u0670'\n    s = re.sub(f'[{re.escape(harakat)}]', '', s)\n    # normalize hamzas alif forms\n    s = s.replace('أ','ا').replace('إ','ا').replace('آ','ا').replace('ؤ','و').replace('ئ','ي').replace('ة','ه')\n    # remove punctuation and non letters/digits/spaces\n    s = re.sub(r'[^\\w\\s\\u0600-\\u06FF]', ' ', s)\n    s = re.sub(r'\\s+', ' ', s).strip()\n    return s\n\nnorm_snip = normalize(\"وإسرافيل وملك الموت\")\nnorm_snip",
      "container_id": "cntr_6896726f579081909ed62b74ec8364b70cdd25efdf890463",
