      "code": "def normalize(s):\n    # remove diacritics\n    s = ''.join(ch for ch in s if not unicodedata.combining(ch))\n    # normalize Arabic letters\n    s = s.replace('إ','ا').replace('أ','ا').replace('آ','ا').replace('ى','ي').replace('ؤ','و').replace('ئ','ي').replace('ة','ه').replace('ٱ','ا')\n    # remove tatweel and punctuation\n    s = re.sub(r'[^\\w\\s]', ' ', s)\n    s = s.replace('ـ','')\n    s = re.sub(r'\\s+',' ', s).strip()\n    return s\n\nnorm_parts=[normalize(p) for p in parts]\nlen(norm_parts), norm_parts[0]",
